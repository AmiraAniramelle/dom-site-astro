---
import BaseLayout from '../../../layouts/BaseLayout.astro';
---

<BaseLayout title="Карта пути | DOM" description="Шесть направлений метода DOM: Деньги, Отношения, Ментальное здоровье, Душа, Осознанность, Мировоззрение.">
  <section class="home-section home-section-tone-soft">
    <div class="max-w-7xl mx-auto px-4 home-surface">
      <h1 class="font-messiri home-title text-dom-graphite mb-8 text-center">Карта пути</h1>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        <a href="/ru/path/money/" class="home-panel p-6 block hover:border-dom-gold/50 transition-colors rounded-2xl border border-dom-gold/25">
          <span class="text-dom-gold font-messiri text-2xl">D</span>
          <h2 class="font-messiri text-xl text-dom-graphite mt-2">Деньги</h2>
        </a>
        <a href="/ru/path/relations/" class="home-panel p-6 block hover:border-dom-gold/50 transition-colors rounded-2xl border border-dom-gold/25">
          <span class="text-dom-gold font-messiri text-2xl">O</span>
          <h2 class="font-messiri text-xl text-dom-graphite mt-2">Отношения</h2>
        </a>
        <a href="/ru/path/mental/" class="home-panel p-6 block hover:border-dom-gold/50 transition-colors rounded-2xl border border-dom-gold/25">
          <span class="text-dom-gold font-messiri text-2xl">M</span>
          <h2 class="font-messiri text-xl text-dom-graphite mt-2">Ментальное здоровье</h2>
        </a>
        <a href="/ru/path/soul/" class="home-panel p-6 block hover:border-dom-gold/50 transition-colors rounded-2xl border border-dom-gold/25">
          <span class="text-dom-gold font-messiri text-2xl">D</span>
          <h2 class="font-messiri text-xl text-dom-graphite mt-2">Душа</h2>
        </a>
        <a href="/ru/path/awareness/" class="home-panel p-6 block hover:border-dom-gold/50 transition-colors rounded-2xl border border-dom-gold/25">
          <span class="text-dom-gold font-messiri text-2xl">O</span>
          <h2 class="font-messiri text-xl text-dom-graphite mt-2">Осознанность</h2>
        </a>
        <a href="/ru/path/worldview/" class="home-panel p-6 block hover:border-dom-gold/50 transition-colors rounded-2xl border border-dom-gold/25">
          <span class="text-dom-gold font-messiri text-2xl">M</span>
          <h2 class="font-messiri text-xl text-dom-graphite mt-2">Мировоззрение</h2>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
