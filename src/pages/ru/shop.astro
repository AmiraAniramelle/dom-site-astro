---
/**
 * Страница «Магазин» — shop-sections/03-shop-page.md, 00-RULES-shop.md
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import ShopHero from '../../components/shop/ShopHero.astro';
import ShopBrandCard from '../../components/shop/ShopBrandCard.astro';
import { createPageMeta } from '../../data/seo/defaults';
import { siteConfig } from '../../data/site';
import { shopPageData } from '../../data/pages/shop';
import type { PageMeta } from '../../types/page';

const baseMeta = createPageMeta({
  ...shopPageData.seo,
  ogType: 'website',
  locale: 'ru_RU',
});

const storeJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Store',
  name: 'Магазин DOM',
  description: 'Лимитированные коллекции MIROZDANIE и DOM',
  url: `${siteConfig.url}/ru/shop/`,
  breadcrumb: {
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Главная',
        item: `${siteConfig.url}/ru/`,
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'Магазин',
        item: `${siteConfig.url}/ru/shop/`,
      },
    ],
  },
};

const meta: PageMeta = {
  ...baseMeta,
  jsonLd: [storeJsonLd],
};
---

<BaseLayout meta={meta}>
  <nav class="sr-only" aria-label="Хлебные крошки">
    <ol class="m-0 list-none p-0">
      <li class="inline">
        <a href="/ru/">Главная</a>
        <span aria-hidden="true"> → </span>
      </li>
      <li class="inline">
        <span aria-current="page">Магазин</span>
      </li>
    </ol>
  </nav>
  <section class="bg-white min-h-screen pt-20 pb-24">
    <div class="max-w-6xl mx-auto px-4">
      <ShopHero {...shopPageData.hero} />
      {shopPageData.brands.map((brand) => (
        <ShopBrandCard {...brand} />
      ))}
    </div>
  </section>
</BaseLayout>
