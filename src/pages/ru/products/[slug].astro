---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ProductHeroNew from '../../../components/products/ProductHeroNew.astro';
import BusinessMissionHero from '../../../components/products/BusinessMissionHero.astro';
import BusinessMissionPainPoints from '../../../components/products/BusinessMissionPainPoints.astro';
import BusinessMissionMainMistake from '../../../components/products/BusinessMissionMainMistake.astro';
import BusinessMissionSystemWork from '../../../components/products/BusinessMissionSystemWork.astro';
import BusinessMissionFormatResults from '../../../components/products/BusinessMissionFormatResults.astro';
import BusinessMissionCourseAudience from '../../../components/products/BusinessMissionCourseAudience.astro';
import ProductMission from '../../../components/products/ProductMission.astro';
import ProductForWhom from '../../../components/products/ProductForWhom.astro';
import ProductResults from '../../../components/products/ProductResults.astro';
import ProductReviews from '../../../components/products/ProductReviews.astro';
import ProductFAQ from '../../../components/products/ProductFAQ.astro';
import ProductEnroll from '../../../components/products/ProductEnroll.astro';
import BusinessMissionEnroll from '../../../components/products/BusinessMissionEnroll.astro';
import { domButtonTextLink } from '../../../data/ui/domButtons';
import { createPageMeta } from '../../../data/seo/defaults';
import { siteConfig } from '../../../data/site';
import type { PageMeta, Breadcrumb } from '../../../types/page';

const CATEGORY_PATH: Record<string, { label: string; path: string }> = {
  money: { label: 'Деньги', path: '/ru/path/money/' },
  relations: { label: 'Отношения', path: '/ru/path/relations/' },
  mental: { label: 'Ментальное здоровье', path: '/ru/path/mental/' },
  soul: { label: 'Душа', path: '/ru/path/soul/' },
  awareness: { label: 'Осознанность', path: '/ru/path/awareness/' },
  worldview: { label: 'Мировоззрение', path: '/ru/path/worldview/' },
};

export async function getStaticPaths() {
  const products = await getCollection('products', (e) => e.data.published && e.data.lang === 'ru');
  return products.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const product = entry.data;
const slug = entry.id;
const { Content } = await render(entry);

/** Meta description ≤ ~160 символов (SEO, DOM-Design-System §15) */
function metaDescriptionForPage(text: string, maxLen = 160): string {
  const t = text.replace(/\s+/g, ' ').trim();
  if (t.length <= maxLen) return t;
  const cut = t.slice(0, maxLen);
  const lastSpace = cut.lastIndexOf(' ');
  return `${(lastSpace > 50 ? cut.slice(0, lastSpace) : cut).trimEnd()}…`;
}

const seoTitle = product.seo.title?.trim();
const seoDescRaw = product.seo.description?.trim();
const pageTitle = seoTitle || `${product.title} | Программы DOM`;
const pageMetaDescription = metaDescriptionForPage(seoDescRaw || product.shortDesc);

const backLinkPath = product.backLink.startsWith('/')
  ? product.backLink
  : `/ru/path/${product.backLink === 'path-money' ? 'money' : product.backLink.replace('path-', '')}/`;

const breadcrumbs: Breadcrumb[] = [
  { name: 'Главная', url: `${siteConfig.url}/ru/` },
  { name: 'Карта пути', url: `${siteConfig.url}/ru/path/` },
  {
    name: CATEGORY_PATH[product.category]?.label ?? product.category,
    url: `${siteConfig.url}${CATEGORY_PATH[product.category]?.path ?? '/ru/path/'}`,
  },
  { name: product.title, url: `${siteConfig.url}/ru/products/${slug}/` },
];

const productPageUrl = `${siteConfig.url}/ru/products/${slug}/`;
const ogImagePath = product.seo.ogImage?.trim();
const ogImageAbsolute = ogImagePath
  ? `${siteConfig.url}${ogImagePath.startsWith('/') ? '' : '/'}${ogImagePath}`
  : undefined;

/** WebPage в `<head>`; крошки дублируются отдельным BreadcrumbList в SEOHead — здесь без breadcrumb */
const webPageJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: product.title,
  description: pageMetaDescription,
  url: productPageUrl,
  isPartOf: { '@type': 'WebSite', name: siteConfig.name, url: siteConfig.url },
};

const courseJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Course',
  name: product.title,
  description: pageMetaDescription,
  url: productPageUrl,
  ...(ogImageAbsolute ? { image: ogImageAbsolute } : {}),
  provider: {
    '@type': 'Organization',
    name: siteConfig.organization.name,
    url: siteConfig.url,
  },
  offers: {
    '@type': 'Offer',
    price: product.price.replace(/\s/g, '').replace(/[^\d]/g, '') || '0',
    priceCurrency: 'RUB',
    url: productPageUrl,
    availability: 'https://schema.org/InStock',
  },
};

const faqJsonLd =
  product.faq && product.faq.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: product.faq.map((item) => ({
          '@type': 'Question',
          name: item.q,
          acceptedAnswer: { '@type': 'Answer', text: item.a },
        })),
      }
    : null;

const productJsonLdBlocks: Record<string, unknown>[] = [webPageJsonLd, courseJsonLd];
if (faqJsonLd) {
  productJsonLdBlocks.push(faqJsonLd);
}

const meta: PageMeta = createPageMeta({
  title: pageTitle,
  description: pageMetaDescription,
  canonicalUrl: `/ru/products/${slug}/`,
  ogImage: product.seo.ogImage,
  ogType: 'product',
  locale: 'ru_RU',
  breadcrumbs,
  jsonLd: productJsonLdBlocks,
});

const businessMissionPillars = product.heroPillars ?? [
  { label: 'ДЕНЬГИ' },
  { label: 'ПОРЯДОК' },
  { label: 'КЛИЕНТЫ' },
];

const backToDirectionLabel = CATEGORY_PATH[product.category]?.label ?? product.category;

const defaultHeroMeta = [
  { label: 'ФОРМАТ', value: 'Онлайн' },
  { label: 'МАТЕРИАЛЫ', value: `${product.modules.length} модулей` },
  { label: 'ДОСТУП', value: 'Сразу после заявки' },
  { label: 'СТОИМОСТЬ', value: product.price },
];

const heroMetaStrip =
  product.meta && product.meta.length > 0 ? product.meta : defaultHeroMeta;

const heroYoutubeId = (product.youtubeId ?? product.heroVideo?.youtubeId)?.trim() ?? '';
const heroVideoCover = product.videoCover ?? product.heroVideo?.posterSrc;

const formatBadge =
  product.format?.trim() ||
  `ОНЛАЙН · ${product.modules.length} МОДУЛЕЙ`;

/** Hero «Бизнес-миссия»: и heroVideo, и отдельные youtubeId / videoCover из frontmatter */
const businessMissionHeroVideo = product.heroVideo?.youtubeId?.trim()
  ? {
      youtubeId: product.heroVideo.youtubeId.trim(),
      posterSrc: product.heroVideo.posterSrc ?? product.videoCover,
      coverSubtitle: product.heroVideo.coverSubtitle,
    }
  : heroYoutubeId
    ? { youtubeId: heroYoutubeId, posterSrc: heroVideoCover, coverSubtitle: product.heroVideo?.coverSubtitle }
    : undefined;
---

<BaseLayout meta={meta}>
  <section class="product-page-shell min-h-screen pb-16 pt-2 md:pb-20 md:pt-3">
    <div
      class="relative z-[1] mx-auto flex w-full max-w-7xl flex-col gap-12 px-4 sm:px-6 md:gap-16 lg:px-8"
    >
    <nav aria-label="Хлебные крошки" class="text-sm text-dom-graphite/80">
      <ol class="flex flex-wrap gap-x-2 gap-y-1">
        {
          breadcrumbs.map((b, i) => (
            <li class="flex items-center gap-2">
              {i > 0 && <span aria-hidden="true">/</span>}
              {i === breadcrumbs.length - 1 ? (
                <span class="font-medium text-dom-graphite">{b.name}</span>
              ) : (
                <a href={b.url.replace(siteConfig.url, '')} class="transition-colors hover:text-dom-gold">
                  {b.name}
                </a>
              )}
            </li>
          ))
        }
      </ol>
    </nav>

    {slug === 'business-mission' ? (
      <div class="flex flex-col gap-2 md:gap-2.5">
        <a href={backLinkPath} class:list={[domButtonTextLink, 'self-start']}>
          {`← К направлению «${backToDirectionLabel}»`}
        </a>
        <BusinessMissionHero
          tag={product.tag}
          title={product.title}
          pillars={businessMissionPillars}
          description={product.shortDesc}
          cta={
            product.heroCta ?? {
              text: 'ЗАНЯТЬ МЕСТО',
              url: '#product-enroll-block',
            }
          }
          metaRows={product.heroMetaRows}
          heroVideo={businessMissionHeroVideo}
        />
      </div>
    ) : (
      <ProductHeroNew
        backLink={{
          text: `← К направлению «${backToDirectionLabel}»`,
          url: backLinkPath,
        }}
        tag={product.tag}
        format={formatBadge}
        title={product.title}
        shortDesc={product.shortDesc}
        youtubeId={heroYoutubeId || undefined}
        videoCover={heroVideoCover}
        primaryCta={{ text: 'Подать заявку', url: '#product-enroll-block' }}
        secondaryCta={{ text: 'Смотреть программу', url: '#product-results' }}
        meta={heroMetaStrip}
      />
    )}

    <ProductMission
      mission={product.mission}
      whyImportant={product.whyImportant}
      theme={slug === 'business-mission' ? 'light' : 'default'}
    />

    <ProductForWhom items={product.forWhom} />

    {slug === 'business-mission' && product.painPoints && product.painPoints.length > 0 ? (
      <BusinessMissionPainPoints
        eyebrow={product.painPointsEyebrow}
        title={product.painPointsTitle}
        items={product.painPoints}
        conclusion={product.painPointsConclusion}
      />
    ) : null}

    {slug === 'business-mission' && product.bmMainMistake ? (
      <BusinessMissionMainMistake data={product.bmMainMistake} />
    ) : null}

    <div id="product-results">
      <ProductResults results={product.results} modules={product.modules} />
    </div>

    {slug === 'business-mission' && product.bmSystemWork ? (
      <BusinessMissionSystemWork data={product.bmSystemWork} />
    ) : null}

    {slug === 'business-mission' && product.bmFormatResults ? (
      <BusinessMissionFormatResults data={product.bmFormatResults} />
    ) : null}

    {slug === 'business-mission' && product.bmCourseAudience ? (
      <BusinessMissionCourseAudience data={product.bmCourseAudience} />
    ) : null}

    <ProductReviews reviews={product.reviews ?? []} />

    <ProductFAQ items={product.faq ?? []} />

    {slug === 'business-mission' && product.bmEnroll ? (
      <BusinessMissionEnroll data={product.bmEnroll} price={product.price} productSlug={slug} />
    ) : (
      <ProductEnroll
        title={product.title}
        shortDesc={product.shortDesc}
        price={product.price}
        tag={product.tag}
        productSlug={slug}
      >
        <div class="prose prose-dom max-w-none">
          <Content />
        </div>
      </ProductEnroll>
    )}
    </div>
  </section>
</BaseLayout>
