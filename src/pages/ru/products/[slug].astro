---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ProductHero from '../../../components/products/ProductHero.astro';
import ProductShowcase from '../../../components/products/ProductShowcase.astro';
import ProductMission from '../../../components/products/ProductMission.astro';
import ProductForWhom from '../../../components/products/ProductForWhom.astro';
import ProductResults from '../../../components/products/ProductResults.astro';
import ProductReviews from '../../../components/products/ProductReviews.astro';
import ProductFAQ from '../../../components/products/ProductFAQ.astro';
import ProductEnroll from '../../../components/products/ProductEnroll.astro';
import { createPageMeta } from '../../../data/seo/defaults';
import { siteConfig } from '../../../data/site';
import type { PageMeta, Breadcrumb } from '../../../types/page';

const CATEGORY_PATH: Record<string, { label: string; path: string }> = {
  money: { label: 'Деньги', path: '/ru/path/money/' },
  relations: { label: 'Отношения', path: '/ru/path/relations/' },
  mental: { label: 'Ментальное здоровье', path: '/ru/path/mental/' },
  soul: { label: 'Душа', path: '/ru/path/soul/' },
  awareness: { label: 'Осознанность', path: '/ru/path/awareness/' },
  worldview: { label: 'Мировоззрение', path: '/ru/path/worldview/' },
};

export async function getStaticPaths() {
  const products = await getCollection('products', (e) => e.data.published && e.data.lang === 'ru');
  return products.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const product = entry.data;
const slug = entry.id;
const { Content } = await render(entry);

const backLinkPath = product.backLink.startsWith('/')
  ? product.backLink
  : `/ru/path/${product.backLink === 'path-money' ? 'money' : product.backLink.replace('path-', '')}/`;

const breadcrumbs: Breadcrumb[] = [
  { name: 'Главная', url: `${siteConfig.url}/ru/` },
  { name: 'Карта пути', url: `${siteConfig.url}/ru/path/` },
  {
    name: CATEGORY_PATH[product.category]?.label ?? product.category,
    url: `${siteConfig.url}${CATEGORY_PATH[product.category]?.path ?? '/ru/path/'}`,
  },
  { name: product.title, url: `${siteConfig.url}/ru/products/${slug}/` },
];

const meta: PageMeta = createPageMeta({
  title: `${product.title} | Программы DOM`,
  description: product.shortDesc,
  canonicalUrl: `/ru/products/${slug}/`,
  ogImage: product.seo.ogImage,
  ogType: 'product',
  locale: 'ru_RU',
  breadcrumbs,
});

const courseJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Course',
  name: product.title,
  description: product.shortDesc,
  provider: {
    '@type': 'Organization',
    name: siteConfig.organization.name,
  },
  offers: {
    '@type': 'Offer',
    price: product.price.replace(/\s/g, '').replace(/[^\d]/g, '') || '0',
    priceCurrency: 'RUB',
  },
};

const faqJsonLd =
  product.faq && product.faq.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: product.faq.map((item) => ({
          '@type': 'Question',
          name: item.q,
          acceptedAnswer: { '@type': 'Answer', text: item.a },
        })),
      }
    : null;
---

<BaseLayout meta={meta}>
  <section class="product-page-shell min-h-screen pt-2 pb-32 md:pt-3">
    <div
      class="mx-auto flex max-w-5xl flex-col gap-8 px-4 sm:px-6 md:gap-16 lg:px-8"
    >
    <nav aria-label="Хлебные крошки" class="sr-only">
      <ol>
        <li><a href="/ru/">Главная</a></li>
        <li><a href="/ru/path/">Карта пути</a></li>
        <li><a href={backLinkPath}>{CATEGORY_PATH[product.category]?.label ?? product.category}</a></li>
        <li>{product.title}</li>
      </ol>
    </nav>

    <ProductHero
      title={product.title}
      tag={product.tag}
      shortDesc={product.shortDesc}
      backLink={{ text: 'Назад к направлению', url: backLinkPath }}
    />

    <ProductShowcase
      title={product.title}
      modulesCount={product.modules.length}
      format="Онлайн"
      access="Сразу после заявки"
    />

    <ProductMission mission={product.mission} whyImportant={product.whyImportant} />

    <ProductForWhom items={product.forWhom} />

    <ProductResults results={product.results} modules={product.modules} />

    <ProductReviews reviews={product.reviews ?? []} />

    <ProductFAQ items={product.faq ?? []} />

    <ProductEnroll
      title={product.title}
      shortDesc={product.shortDesc}
      price={product.price}
      tag={product.tag}
      productSlug={slug}
    >
      <div class="prose prose-dom max-w-none">
        <Content />
      </div>
    </ProductEnroll>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(courseJsonLd)} />
  {faqJsonLd && <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />}
</BaseLayout>
