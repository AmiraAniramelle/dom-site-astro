---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AboutLifeHero from '../../components/about-life/AboutLifeHero.astro';
import AboutLifeStory from '../../components/about-life/AboutLifeStory.astro';
import AboutLifeStageCard from '../../components/about-life/AboutLifeStageCard.astro';
import { createPageMeta } from '../../data/seo/defaults';
import { siteConfig } from '../../data/site';
import type { Breadcrumb } from '../../types/page';
import { aboutLifePageData } from '../../data/pages/about-life';

const breadcrumbs: Breadcrumb[] = [
  { name: 'Главная', url: `${siteConfig.url}/ru/` },
  { name: 'Об авторе', url: `${siteConfig.url}/ru/about/` },
  { name: 'История жизни', url: `${siteConfig.url}/ru/about-life/` },
];

const meta = createPageMeta({
  title: aboutLifePageData.seo.title,
  description: aboutLifePageData.seo.description,
  canonicalUrl: aboutLifePageData.seo.canonicalUrl,
  ogType: 'article',
  locale: 'ru_RU',
  author: 'Анна Камаллая Хефорс',
  breadcrumbs,
});

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'История жизни Анны Хефорс',
  author: { '@type': 'Person', name: 'Анна Камаллая Хефорс' },
  breadcrumb: {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Главная', item: `${siteConfig.url}/ru/` },
      { '@type': 'ListItem', position: 2, name: 'Об авторе', item: `${siteConfig.url}/ru/about/` },
      {
        '@type': 'ListItem',
        position: 3,
        name: 'История жизни',
        item: `${siteConfig.url}/ru/about-life/`,
      },
    ],
  },
};
---

<BaseLayout meta={meta}>
  <nav aria-label="Хлебные крошки" class="breadcrumbs text-sm">
    <ol>
      {breadcrumbs.map((b, i) => (
        <li>
          {i > 0 && ' / '}
          {i === breadcrumbs.length - 1 ? (
            <span>{b.name}</span>
          ) : (
            <a href={b.url.replace(siteConfig.url, '')}>{b.name}</a>
          )}
        </li>
      ))}
    </ol>
  </nav>

  <section class="bg-white min-h-screen pb-28 futuristic-grid">
    <div class="max-w-6xl mx-auto px-4 fade-in">
      <AboutLifeHero {...aboutLifePageData.hero} />
      <AboutLifeStory {...aboutLifePageData.story} />
      <div class="space-y-5">
        {aboutLifePageData.stages.map((stage) => (
          <AboutLifeStageCard {...stage} />
        ))}
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />
</BaseLayout>
