  <section class="home-section home-section-tone-soft">
    <div class="max-w-4xl mx-auto px-4 home-surface">
      <h1 class="font-messiri home-title text-dom-graphite mb-6">Приложение DOM</h1>
      <p class="home-subtitle font-montserrat text-dom-graphite mb-4">DOM для iOS и Android. Meditation & Balance.</p>
      <div class="flex flex-wrap gap-4">
        <a href="https://apps.apple.com/kw/app/it-brain-meditation-balance/id6478028341" target="_blank" rel="noopener noreferrer" class="px-6 py-3 bg-dom-graphite text-dom-gold rounded-xl font-montserrat">App Store</a>
        <a href="https://play.google.com/store/apps/details?id=pro.appfyl.dmtmeditation&hl=en" target="_blank" rel="noopener noreferrer" class="px-6 py-3 bg-dom-graphite text-dom-gold rounded-xl font-montserrat">Google Play</a>
