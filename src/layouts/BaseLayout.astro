---
import type { PageMeta } from '../types/page';
import { siteConfig } from '../data/site';
import SEOHead from '../components/global/SEOHead.astro';
import Navbar from '../components/Navbar.astro';
import FooterSection from '../components/Footer/FooterSection.astro';
import '../styles/global.css';
import '../styles/buttons.css';
import '../styles/footer-and-final-cta.css';
import '../styles/method-subscription.css';

interface Props {
  /** Полный объект мета (для страниц продукта, блога и т.д.) */
  meta?: PageMeta;
  /** Устаревшие пропсы — если meta не передан, мета собирается из них */
  title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

const { meta: metaProp, title: titleLegacy, description: descriptionLegacy, image: imageLegacy, noindex = false } = Astro.props;

const canonicalFromUrl = Astro.url.pathname.endsWith('/') ? Astro.url.pathname : Astro.url.pathname + '/';
const canonicalUrlFull = `${siteConfig.url}${canonicalFromUrl}`;

const meta: PageMeta = metaProp ?? {
  title: titleLegacy ?? 'DOM | Системный Метод Анны Хефорс',
  description: descriptionLegacy ?? 'Системный метод Анны Хефорс — путь к деньгам, отношениям, ментальному здоровью и осознанности.',
  canonicalUrl: canonicalUrlFull,
  ogImage: imageLegacy ?? siteConfig.defaultOgImage,
  ogType: 'website',
  locale: 'ru_RU',
  noIndex: noindex,
};
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SEOHead meta={meta} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600;700&family=Montserrat:wght@300;400;500;600&display=swap&subset=cyrillic,cyrillic-ext" rel="stylesheet" />
  </head>
  <body>
    <Navbar />
    <main class="pt-24 md:pt-28 min-h-screen">
      <div class="main-scale-wrap">
        <slot />
      </div>
    </main>
    <FooterSection />
  </body>
</html>
