---
import type { LegalLink } from '../../data/footer';

interface Props {
  year: string;
  brand: string;
  links: LegalLink[];
}

const { year, brand, links } = Astro.props;
---

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-6 pt-4 border-t border-dom-gold/20 relative z-10">
  <p class="text-sm text-dom-beige/75 font-montserrat text-center tracking-[0.01em]">
    © {year} {brand}
    {links.map((link, i) => (
      <>
        <span class="mx-2 text-dom-gold/70">•</span>
        <a href={link.href} target="_blank" rel="noopener noreferrer" class="hover:text-dom-gold transition-colors">{link.title}</a>
      </>
    ))}
  </p>
</div>
