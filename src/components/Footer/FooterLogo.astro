---
interface Props {
  copyrightText: string;
  homeUrl?: string;
}

const { copyrightText, homeUrl = '/ru/' } = Astro.props;
const logoSrc = '/images/shared/DOM%20%D1%80%D0%B0%D1%81%D1%88%D0%B8%D1%80%D0%B5%D0%BD%D0%BD%D0%B0%D1%8F%20%D0%B2%D0%B5%D1%80%D1%81%D0%B8%D1%8F%202%20%D0%B3%D1%80%D0%B0%D0%B4%D0%B8%D0%B5%D0%BD%D1%82.png';
---

<div>
  <a href={homeUrl} class="inline-block" aria-label="DOM — на главную">
    <img
      src={logoSrc}
      alt="DOM — системный метод Анны Хефорс"
      class="brand-logo h-36 md:h-44 w-auto object-contain"
      loading="lazy"
      decoding="async"
    />
  </a>
  <p class="mt-3 text-[11px] font-montserrat text-dom-beige/70">{copyrightText}</p>
</div>
