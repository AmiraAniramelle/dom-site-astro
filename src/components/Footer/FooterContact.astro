---
import type { Contact, SocialLink } from '../../data/footer';

interface Props {
  contact: Contact;
  socialLinks: SocialLink[];
  heading?: string;
  socialHeading?: string;
}

const { contact, socialLinks, heading = 'Связаться с нами', socialHeading = 'Соцсети' } = Astro.props;

const linkClass = 'w-9 h-9 inline-flex items-center justify-center border border-dom-gold/35 rounded-full text-dom-beige hover:bg-dom-gold hover:text-dom-graphite transition-colors';
---

<div>
  <h4 class="font-bold mb-2 text-white font-messiri text-xl">{heading}</h4>
  <p class="text-sm opacity-80 font-montserrat">
    Telegram: <a href={contact.telegram} target="_blank" rel="noopener noreferrer" class="text-dom-gold hover:underline">{contact.telegramLabel}</a>
    {contact.email && (
      <span class="block mt-1">Email: <a href={`mailto:${contact.email}`} class="text-dom-gold hover:underline">{contact.email}</a></span>
    )}
  </p>
  <div class="mt-3">
    <p class="text-xs uppercase tracking-[0.12em] text-dom-gold/85 font-montserrat mb-2">{socialHeading}</p>
    <div class="flex flex-wrap gap-2">
      {socialLinks.map((social) => (
        <a href={social.href} target="_blank" rel="noopener noreferrer" aria-label={social.label} title={social.title ?? social.label} class={linkClass}>
          {social.label === 'YouTube' && (
            <svg viewBox="0 0 24 24" class="w-5 h-5 fill-current" aria-hidden="true"><path d="M21.58 7.19a2.98 2.98 0 0 0-2.1-2.1C17.63 4.6 12 4.6 12 4.6s-5.63 0-7.48.49a2.98 2.98 0 0 0-2.1 2.1C2 9.04 2 12 2 12s0 2.96.42 4.81a2.98 2.98 0 0 0 2.1 2.1c1.85.49 7.48.49 7.48.49s5.63 0 7.48-.49a2.98 2.98 0 0 0 2.1-2.1C22 14.96 22 12 22 12s0-2.96-.42-4.81ZM10.2 15.15V8.85L15.65 12l-5.45 3.15Z"/></svg>
          )}
          {social.label === 'Telegram' && (
            <svg viewBox="0 0 24 24" class="w-5 h-5 fill-current" aria-hidden="true"><path d="M20.67 4.37 3.83 10.86c-1.15.46-1.14 1.1-.2 1.39l4.32 1.35 1.66 5.17c.2.57.1.79.7.79.46 0 .66-.21.92-.47l2.24-2.17 4.66 3.44c.86.48 1.47.23 1.69-.8l2.87-13.53c.32-1.26-.48-1.83-1.32-1.46Zm-11 8.9-.37 3.62-.82-2.7 8.7-5.5-7.51 4.58Z"/></svg>
          )}
          {social.label === 'Instagram' && (
            <svg viewBox="0 0 24 24" class="w-5 h-5 fill-current" aria-hidden="true"><path d="M12 7.15A4.85 4.85 0 1 0 12 16.85 4.85 4.85 0 0 0 12 7.15Zm0 8.1A3.25 3.25 0 1 1 12 8.75a3.25 3.25 0 0 1 0 6.5Z"/><path d="M16.96 2.8H7.04A4.25 4.25 0 0 0 2.8 7.04v9.92a4.25 4.25 0 0 0 4.24 4.24h9.92a4.25 4.25 0 0 0 4.24-4.24V7.04A4.25 4.25 0 0 0 16.96 2.8Zm2.64 14.16a2.65 2.65 0 0 1-2.64 2.64H7.04A2.65 2.65 0 0 1 4.4 16.96V7.04A2.65 2.65 0 0 1 7.04 4.4h9.92a2.65 2.65 0 0 1 2.64 2.64v9.92Z"/><circle cx="17.35" cy="6.65" r="1.1"/></svg>
          )}
        </a>
      ))}
    </div>
  </div>
</div>
