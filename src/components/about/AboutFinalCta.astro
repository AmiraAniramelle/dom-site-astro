---
/**
 * Блок 11: Финальный CTA (about-sections/11-final-cta.md, source-DOM ~6420–6433)
 * Фон: path-internal-house-card (как внутренний DOM на карте пути)
 */
interface Props {
  /** Крупная золотая строка (в оригинале — цитата) */
  title: string;
  description: string;
  cta: { text: string; url: string };
  secondaryCta?: { text: string; url: string };
}

const { title, description, cta, secondaryCta } = Astro.props;
---

<article
  class="path-internal-house-card rounded-[2.4rem] p-6 md:p-11 border border-dom-gold/35 shadow-2xl text-center relative overflow-hidden"
>
  <div
    class="absolute -top-20 -right-16 w-64 h-64 bg-dom-gold/12 rounded-full blur-3xl pointer-events-none hidden md:block"
    aria-hidden="true"
  ></div>
  <p
    class="font-messiri text-dom-gold mb-5 relative z-10 text-[clamp(1.4rem,6vw,1.8rem)] md:text-3xl lg:text-4xl"
  >
    {title}
  </p>
  <p class="font-montserrat text-sm md:text-base text-dom-beige/80 max-w-4xl mx-auto mb-6 relative z-10 leading-[1.7] md:leading-normal">
    {description}
  </p>
  <div class="relative z-10 flex flex-col w-full md:w-auto md:flex-row gap-3 justify-center items-stretch md:items-center">
    <a
      href={cta.url}
      class="inline-flex w-full md:w-auto justify-center px-8 py-3 bg-gold-gradient text-white rounded-xl font-montserrat font-semibold uppercase tracking-[0.08em] text-xs shadow-[0_12px_28px_rgba(217,179,114,0.36)] no-underline"
    >
      {cta.text}
    </a>
    {secondaryCta ? (
      <a
        href={secondaryCta.url}
        class="inline-flex w-full md:w-auto justify-center px-8 py-3 border border-dom-gold/45 text-dom-gold rounded-xl hover:bg-dom-gold/15 transition font-montserrat font-semibold uppercase tracking-[0.08em] text-xs no-underline"
      >
        {secondaryCta.text}
      </a>
    ) : null}
  </div>
</article>
