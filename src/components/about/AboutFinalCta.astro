---
/**
 * Блок 11: Финальный CTA (about-sections/11-final-cta.md, source-DOM ~6420–6433)
 * Фон: path-internal-house-card (как внутренний DOM на карте пути)
 */
interface Props {
  /** Крупная золотая строка (в оригинале — цитата) */
  title: string;
  description: string;
  cta: { text: string; url: string };
  secondaryCta?: { text: string; url: string };
}

const { title, description, cta, secondaryCta } = Astro.props;
---

<article
  class="path-internal-house-card rounded-2xl md:rounded-[2rem] p-8 md:p-10 lg:p-11 border border-dom-gold/35 shadow-2xl text-center relative overflow-hidden"
>
  <div
    class="absolute -top-20 -right-16 w-64 h-64 bg-dom-gold/12 rounded-full blur-3xl pointer-events-none hidden md:block"
    aria-hidden="true"
  ></div>
  <h2
    class="font-messiri text-dom-gold mb-4 md:mb-5 relative z-10 text-[clamp(1.5rem,7vw,2rem)] md:text-3xl lg:text-4xl leading-tight"
  >
    {title}
  </h2>
  <p
    class="font-montserrat text-sm md:text-base lg:text-lg text-dom-beige/85 max-w-4xl mx-auto mb-6 md:mb-8 relative z-10 leading-relaxed"
  >
    {description}
  </p>
  <div
    class="relative z-10 flex flex-col w-full md:w-auto md:flex-row gap-3 md:gap-4 justify-center items-stretch md:items-center"
  >
    <!-- Тип 2 (dom-btn-secondary): переходы по сайту, не главная золотая CTA -->
    <a href={cta.url} class="dom-btn-secondary w-full md:w-auto">
      {cta.text}
    </a>
    {secondaryCta ? (
      <a href={secondaryCta.url} class="dom-btn-secondary w-full md:w-auto">
        {secondaryCta.text}
      </a>
    ) : null}
  </div>
</article>
