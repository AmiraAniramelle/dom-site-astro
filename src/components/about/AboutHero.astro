---
/**
 * Блок 1: Hero — Об авторе (кнопки как на главной: dom-btn-primary / dom-btn-secondary)
 */
interface Props {
  title: string;
  description: string;
  primaryCta: { text: string; url: string };
  secondaryCta: { text: string; url: string };
  portrait: { src: string; alt: string; width: number; height: number };
  stats: Array<{ value: string; label: string }>;
}

const { title, description, primaryCta, secondaryCta, portrait, stats } = Astro.props;
---

<div class="space-y-8 md:space-y-10 about-hero-stack mb-8 md:mb-16">
  <article
    class="rounded-2xl border-2 border-dom-gold/50 p-8 md:p-10 shadow-[0_20px_44px_rgba(126,91,35,0.18)] bg-[linear-gradient(150deg,#fff7e8_0%,#f5e2bc_58%,#f1d8aa_100%)]"
  >
    <div
      class="about-hero-grid grid grid-cols-1 lg:grid-cols-12 gap-8 lg:items-stretch lg:min-h-[min(520px,70vh)]"
    >
      <div
        class="about-hero-copy lg:col-span-7 flex flex-col lg:h-full lg:min-h-0 lg:justify-between gap-6 lg:gap-8"
      >
        <div class="about-hero-copy-top space-y-4 md:space-y-5 lg:space-y-0 lg:mb-0">
          <h1 class="hero-title text-dom-graphite mb-0">
            {title}
          </h1>
          <p
            class="about-hero-lead font-montserrat text-sm md:text-base lg:text-lg text-dom-graphite leading-relaxed mb-0 lg:mt-4"
          >
            {description}
          </p>
        </div>
        <div class="about-hero-ctas flex flex-col md:flex-row gap-3 lg:shrink-0 lg:pt-2">
          <a href={primaryCta.url} class="dom-btn-primary w-full md:w-auto">
            {primaryCta.text}
          </a>
          <a href={secondaryCta.url} class="dom-btn-secondary w-full md:w-auto">
            {secondaryCta.text}
          </a>
        </div>
      </div>
      <div
        class="about-hero-portrait lg:col-span-5 flex flex-col lg:h-full lg:min-h-0"
      >
        <div
          class="about-hero-portrait-frame flex-1 min-h-[280px] lg:min-h-0 h-full rounded-[2rem] overflow-hidden border border-dom-gold/25 shadow-[0_10px_24px_rgba(126,91,35,0.12)]"
        >
          <img
            src={portrait.src}
            alt={portrait.alt}
            class="w-full h-[340px] lg:h-full object-cover object-[50%_32%]"
            width={portrait.width}
            height={portrait.height}
            loading="eager"
            fetchpriority="high"
          />
        </div>
      </div>
    </div>
  </article>

  <article class="about-hero-stats grid grid-cols-2 md:grid-cols-2 lg:grid-cols-4 gap-4">
    {stats.map((stat) => (
      <div
        class="rounded-2xl p-5 md:p-6 border border-dom-gold/45 bg-[linear-gradient(145deg,rgba(255,255,255,0.97),rgba(246,234,205,0.92))] shadow-[0_10px_24px_rgba(126,91,35,0.12)] hover:-translate-y-1 hover:shadow-[0_16px_30px_rgba(126,91,35,0.2)] transition-all duration-300"
      >
        <p class="about-stat-value font-messiri text-4xl md:text-5xl text-dom-goldDark leading-none mb-2">
          {stat.value}
        </p>
        <p class="about-stat-label font-montserrat text-base md:text-lg text-dom-graphite/82">{stat.label}</p>
      </div>
    ))}
  </article>
</div>
