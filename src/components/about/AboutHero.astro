---
/**
 * Блок 1: Hero — Об авторе (about-sections/01-hero.md, source-DOM ~6185–6226)
 * Мобильные отступы/порядок — в about.css (@media max-width: 767px), десктоп без изменений.
 */
interface Props {
  title: string;
  description: string;
  primaryCta: { text: string; url: string };
  secondaryCta: { text: string; url: string };
  portrait: { src: string; alt: string; width: number; height: number };
  stats: Array<{ value: string; label: string }>;
}

const { title, description, primaryCta, secondaryCta, portrait, stats } = Astro.props;
---

<div class="space-y-10 about-hero-stack mb-8 md:mb-12 lg:mb-14">
  <article
    class="about-light-card about-hero-main rounded-[2.6rem] p-7 md:p-10 bg-[linear-gradient(150deg,#fff7e8_0%,#f5e2bc_58%,#f1d8aa_100%)]"
  >
    <div class="about-hero-grid grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
      <div class="about-hero-copy lg:col-span-7">
        <h1 class="about-hero-title font-messiri text-5xl md:text-6xl text-dom-graphite mb-4">
          {title}
        </h1>
        <p class="about-hero-lead font-montserrat text-lg md:text-xl text-dom-graphite/82 leading-relaxed mb-7">
          {description}
        </p>
        <div class="about-hero-ctas flex flex-col sm:flex-row gap-3">
          <a
            href={primaryCta.url}
            class="inline-flex justify-center px-8 py-3 border border-dom-gold/45 text-dom-goldDark rounded-xl hover:bg-dom-gold/15 transition font-montserrat font-semibold uppercase tracking-[0.08em] text-xs text-center no-underline"
          >
            {primaryCta.text}
          </a>
          <a
            href={secondaryCta.url}
            class="inline-flex justify-center px-8 py-3 bg-gold-gradient text-white rounded-xl font-montserrat font-semibold uppercase tracking-[0.08em] text-xs shadow-[0_12px_28px_rgba(217,179,114,0.36)] text-center no-underline"
          >
            {secondaryCta.text}
          </a>
        </div>
      </div>
      <div class="about-hero-portrait lg:col-span-5">
        <div
          class="about-hero-portrait-frame rounded-[2rem] overflow-hidden border border-dom-gold/25 shadow-[0_20px_42px_rgba(0,0,0,0.2)]"
        >
          <img
            src={portrait.src}
            alt={portrait.alt}
            class="w-full h-[340px] md:h-[540px] object-cover object-[50%_32%]"
            width={portrait.width}
            height={portrait.height}
            loading="eager"
            fetchpriority="high"
          />
        </div>
      </div>
    </div>
  </article>

  <article class="about-hero-stats grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
    {stats.map((stat) => (
      <div
        class="about-stat-card rounded-2xl p-5 md:p-6 border border-dom-gold/45 bg-[linear-gradient(145deg,rgba(255,255,255,0.97),rgba(246,234,205,0.92))] shadow-[0_10px_24px_rgba(126,91,35,0.12)] transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_16px_30px_rgba(126,91,35,0.2)]"
      >
        <p class="about-stat-value font-messiri text-4xl md:text-5xl text-dom-goldDark leading-none mb-2">
          {stat.value}
        </p>
        <p class="about-stat-label font-montserrat text-base md:text-lg text-dom-graphite/82">{stat.label}</p>
      </div>
    ))}
  </article>
</div>
