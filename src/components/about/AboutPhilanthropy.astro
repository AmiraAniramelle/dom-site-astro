---
/**
 * Блок 3: Филантропия (about-sections/03-philanthropy.md, source-DOM ~6242–6255)
 */
interface Props {
  eyebrow: string;
  title: string;
  text: string;
  image: { src: string; alt: string; width?: number; height?: number };
  /** Подпись под фото (как figcaption в оригинале) */
  imageCaption?: string;
}

const { eyebrow, title, text, image, imageCaption } = Astro.props;
const imgW = image.width ?? 1200;
const imgH = image.height ?? 800;
const imgSrc = encodeURI(image.src);
---

<article class="about-light-card rounded-2xl p-8 md:p-10">
  <p
    class="font-montserrat text-[11px] uppercase tracking-[0.12em] text-dom-goldDark mb-2 md:mb-3 block text-center md:text-left"
  >
    {eyebrow}
  </p>
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-center">
    <div class="order-2 lg:order-none lg:col-span-7">
      <h2
        class="font-messiri text-dom-graphite mb-4 md:mb-6 text-[clamp(1.5rem,7vw,2rem)] md:text-4xl lg:text-5xl text-center md:text-left leading-tight"
      >
        {title}
      </h2>
      <p class="font-montserrat text-sm md:text-base lg:text-lg text-dom-graphite leading-relaxed text-left">
        {text}
      </p>
    </div>
    <figure
      class="order-1 lg:order-none lg:col-span-5 w-full rounded-xl md:rounded-2xl overflow-hidden border border-dom-gold/25 bg-white/60 p-0 md:p-3 mb-4 md:mb-0"
    >
      <img
        src={imgSrc}
        alt={image.alt}
        class="w-full h-[300px] md:h-[360px] object-cover object-center rounded-xl"
        width={imgW}
        height={imgH}
        loading="lazy"
      />
      {imageCaption ? (
        <figcaption class="font-montserrat text-sm text-dom-graphite/72 mt-3">{imageCaption}</figcaption>
      ) : null}
    </figure>
  </div>
</article>
