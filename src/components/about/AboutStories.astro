---
/**
 * Блок 10: Истории людей (about-sections/10-stories.md, source-DOM ~6409–6417)
 */
interface Story {
  name: string;
  text: string;
  photo?: string;
}

interface Props {
  title: string;
  stories: Story[];
  intro?: string;
  cta?: { text: string; url: string };
}

const { title, stories, intro, cta } = Astro.props;
---

<article class="about-light-card rounded-2xl p-8 md:p-10">
  <h2
    class="font-messiri text-dom-graphite mb-4 md:mb-6 text-[clamp(1.5rem,7vw,2rem)] md:text-4xl lg:text-5xl text-center md:text-left leading-tight"
  >
    {title}
  </h2>
  {intro ? (
    <p
      class="font-montserrat text-sm md:text-base lg:text-lg text-dom-graphite leading-relaxed mb-5 md:mb-6 text-left"
    >
      {intro}
    </p>
  ) : null}
  {stories.length > 0 ? (
    <div class="flex flex-col gap-0 md:grid md:grid-cols-2 md:gap-8 mb-6 md:mb-10">
      {stories.map((s) => (
        <div
          class="about-story-card bg-white rounded-2xl border border-dom-gold/25 p-5 md:p-8 shadow-[0_10px_24px_rgba(126,91,35,0.1)]"
        >
          {s.photo ? (
            <>
              <div class="hidden md:block mb-3 rounded-xl overflow-hidden border border-dom-gold/20">
                <img
                  src={encodeURI(s.photo)}
                  alt={s.name}
                  class="w-full h-40 object-cover"
                  width="320"
                  height="160"
                  loading="lazy"
                />
              </div>
              <div class="flex md:hidden items-center gap-3 mb-2">
                <img
                  src={encodeURI(s.photo)}
                  alt={s.name}
                  class="w-12 h-12 rounded-full object-cover shrink-0"
                  width="48"
                  height="48"
                  loading="lazy"
                />
                <p class="font-messiri text-lg text-dom-graphite">{s.name}</p>
              </div>
              <p class="hidden md:block font-messiri text-lg text-dom-graphite mb-2">{s.name}</p>
            </>
          ) : (
            <p class="font-messiri text-lg text-dom-graphite mb-2">{s.name}</p>
          )}
          <p class="font-montserrat text-sm md:text-base text-dom-graphite leading-relaxed">{s.text}</p>
        </div>
      ))}
    </div>
  ) : null}
  {cta ? (
    <a href={cta.url} class="dom-btn-secondary w-full md:w-auto">
      {cta.text}
    </a>
  ) : null}
</article>
