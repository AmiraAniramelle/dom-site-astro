---
/**
 * Блок 9: Приложение DOM (about-sections/09-app.md, source-DOM ~6385–6406)
 */
interface Props {
  title: string;
  /** Один или несколько абзацев через \n\n */
  description: string;
  image: { src: string; alt: string; width?: number; height?: number };
  cta: { text: string; url: string };
  /** Вторая строка над заголовком («Приложение DOM») */
  sublabel?: string;
}

const { title, description, image, cta, sublabel } = Astro.props;
const imgW = image.width ?? 800;
const imgH = image.height ?? 1600;
const imgSrc = encodeURI(image.src);
const paragraphs = description.split(/\n\n+/).map((p) => p.trim()).filter(Boolean);
---

<article class="about-light-card rounded-2xl p-8 md:p-10">
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-center">
    <div class="order-2 lg:order-none lg:col-span-6 text-center lg:text-left">
      {sublabel ? (
        <p
          class="font-montserrat text-[11px] uppercase tracking-[0.12em] text-dom-goldDark mb-2 block lg:text-left"
        >
          {sublabel}
        </p>
      ) : null}
      <h2
        class="font-messiri text-dom-graphite mb-4 md:mb-6 text-[clamp(1.5rem,7vw,2rem)] md:text-4xl lg:text-5xl lg:text-left leading-tight"
      >
        {title}
      </h2>
      {paragraphs.map((para, i) => (
        <p
          class:list={[
            'font-montserrat text-sm md:text-base lg:text-lg text-dom-graphite leading-relaxed lg:text-left',
            i < paragraphs.length - 1 ? 'mb-4' : 'mb-6',
          ]}
        >
          {para}
        </p>
      ))}
      <a href={cta.url} class="dom-btn-secondary w-full lg:w-auto">
        {cta.text}
      </a>
    </div>
    <div class="order-1 lg:order-none lg:col-span-6 w-full">
      <div
        class="rounded-xl overflow-hidden border border-dom-gold/25 bg-[linear-gradient(135deg,rgba(42,33,21,0.96),rgba(88,65,33,0.92))] p-2 md:p-4 md:rounded-[1.8rem] md:shadow-[0_18px_38px_rgba(0,0,0,0.24)]"
      >
        <img
          src={imgSrc}
          alt={image.alt}
          class="w-full h-auto rounded-xl border border-dom-gold/25"
          width={imgW}
          height={imgH}
          loading="lazy"
        />
      </div>
    </div>
  </div>
</article>
