---
/**
 * Блок 7: Метод DOM (about-sections/07-method.md, source-DOM ~6332–6348)
 */
interface House {
  title: string;
  /** Вторая строка карточки (как «Деньги · Отношения · …» в оригинале) */
  subtitle?: string;
  description: string;
}

interface Props {
  title: string;
  houses: House[];
  eyebrow?: string;
  /** Два заключительных абзаца под сеткой */
  footerParagraphs?: string[];
  cta?: { text: string; url: string };
}

const { title, houses, eyebrow, footerParagraphs = [], cta } = Astro.props;
---

<article class="about-light-card rounded-[2.2rem] p-7 md:p-9">
  {eyebrow ? (
    <p
      class="font-montserrat text-[10px] md:text-[11px] uppercase tracking-[0.12em] text-dom-goldDark mb-3 text-center md:text-left"
    >
      {eyebrow}
    </p>
  ) : null}
  <h2
    class="font-messiri text-dom-graphite mb-6 text-[clamp(1.4rem,6vw,1.8rem)] md:text-4xl text-center md:text-left"
  >
    {title}
  </h2>
  <div class="flex flex-col md:grid md:grid-cols-2 gap-0 md:gap-5 mb-5">
    {houses.map((house) => (
      <div class="about-method-house bg-white/70 border border-dom-gold/20 rounded-2xl p-5">
        <h4 class="font-messiri text-xl md:text-2xl text-dom-graphite mb-2">{house.title}</h4>
        {house.subtitle ? (
          <p class="font-montserrat text-sm text-dom-graphite/78 mb-2">{house.subtitle}</p>
        ) : null}
        <p class="font-montserrat text-sm text-dom-graphite/78 leading-[1.7] md:leading-normal">{house.description}</p>
      </div>
    ))}
  </div>
  {footerParagraphs.map((para, i) => (
    <p
      class:list={[
        'font-montserrat text-sm md:text-base text-dom-graphite/78 leading-[1.7] md:leading-relaxed text-left',
        i < footerParagraphs.length - 1 ? 'mb-3' : '',
      ]}
    >
      {para}
    </p>
  ))}
  {cta ? (
    <a
      href={cta.url}
      class="inline-flex w-full md:w-auto justify-center mt-6 px-8 py-3 bg-gold-gradient text-white rounded-xl font-montserrat font-semibold uppercase tracking-[0.08em] text-xs shadow-[0_10px_24px_rgba(166,120,50,0.3)] no-underline"
    >
      {cta.text}
    </a>
  ) : null}
</article>
