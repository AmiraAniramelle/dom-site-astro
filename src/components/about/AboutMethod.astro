---
/**
 * Блок 7: Метод DOM (about-sections/07-method.md, source-DOM ~6332–6348)
 */
interface House {
  title: string;
  /** Вторая строка карточки (как «Деньги · Отношения · …» в оригинале) */
  subtitle?: string;
  description: string;
}

interface Props {
  title: string;
  houses: House[];
  /** Два заключительных абзаца под сеткой */
  footerParagraphs?: string[];
  cta?: { text: string; url: string };
}

const { title, houses, footerParagraphs = [], cta } = Astro.props;
---

<article class="about-light-card rounded-2xl p-8 md:p-10">
  <h2
    class="font-messiri text-dom-graphite mb-6 md:mb-10 text-[clamp(1.5rem,7vw,2rem)] md:text-4xl lg:text-5xl text-center md:text-left leading-tight"
  >
    {title}
  </h2>
  <div class="flex flex-col md:grid md:grid-cols-2 gap-4 md:gap-8 mb-6">
    {houses.map((house) => (
      <div
        class="about-method-house bg-white rounded-2xl border border-dom-gold/25 p-5 md:p-8 shadow-[0_10px_24px_rgba(126,91,35,0.1)]"
      >
        <h3 class="font-messiri text-xl md:text-2xl text-dom-graphite mb-2">{house.title}</h3>
        {house.subtitle ? (
          <p class="font-montserrat text-sm text-dom-graphite mb-2">{house.subtitle}</p>
        ) : null}
        <p class="font-montserrat text-sm md:text-base text-dom-graphite leading-relaxed">{house.description}</p>
      </div>
    ))}
  </div>
  {footerParagraphs.map((para, i) => (
    <p
      class:list={[
        'font-montserrat text-sm md:text-base lg:text-lg text-dom-graphite leading-relaxed text-left',
        i < footerParagraphs.length - 1 ? 'mb-4 md:mb-6' : '',
      ]}
    >
      {para}
    </p>
  ))}
  {cta ? (
    <a href={cta.url} class="dom-btn-secondary w-full md:w-auto mt-6">
      {cta.text}
    </a>
  ) : null}
</article>
