---
/**
 * Блок 5: Философия DOM (about-sections/05-philosophy.md, source-DOM ~6274–6298)
 */
interface Props {
  title: string;
  principles: Array<{ title: string; description: string }>;
  /** Как в оригинале — строка над заголовком */
  eyebrow?: string;
}

const { title, principles, eyebrow } = Astro.props;
---

<article class="about-light-card rounded-2xl p-8 md:p-10">
  {eyebrow ? (
    <p
      class="font-montserrat text-[11px] uppercase tracking-[0.12em] text-dom-goldDark mb-2 md:mb-3 block text-center md:text-left"
    >
      {eyebrow}
    </p>
  ) : null}
  <h2
    class="font-messiri text-dom-graphite mb-4 md:mb-6 text-[clamp(1.5rem,7vw,2rem)] md:text-4xl lg:text-5xl text-center md:text-left leading-tight"
  >
    {title}
  </h2>
  <div class="flex flex-col gap-4 md:gap-6">
    {principles.map((item) => (
      <div
        class="about-principle-item bg-white rounded-2xl border border-dom-gold/25 p-5 md:p-8 shadow-[0_10px_24px_rgba(126,91,35,0.1)]"
      >
        <h3 class="font-messiri text-[clamp(1.1rem,5vw,1.3rem)] md:text-2xl text-dom-graphite mb-2 md:mb-3">
          {item.title}
        </h3>
        <p class="font-montserrat text-sm md:text-base text-dom-graphite leading-relaxed">{item.description}</p>
      </div>
    ))}
  </div>
</article>
