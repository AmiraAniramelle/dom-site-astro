---
/**
 * Блок 5: Философия DOM (about-sections/05-philosophy.md, source-DOM ~6274–6298)
 */
interface Props {
  title: string;
  principles: Array<{ title: string; description: string }>;
  /** Как в оригинале — строка над заголовком */
  eyebrow?: string;
}

const { title, principles, eyebrow } = Astro.props;
---

<article class="about-light-card rounded-[2.2rem] p-7 md:p-9">
  {eyebrow ? (
    <p
      class="font-montserrat text-[10px] md:text-[11px] uppercase tracking-[0.12em] text-dom-goldDark mb-3 text-center md:text-left"
    >
      {eyebrow}
    </p>
  ) : null}
  <h2
    class="font-messiri text-dom-graphite mb-4 md:mb-6 text-[clamp(1.4rem,6vw,1.8rem)] md:text-4xl text-center md:text-left"
  >
    {title}
  </h2>
  <div class="flex flex-col gap-4 md:gap-4">
    {principles.map((item) => (
      <div class="about-principle-item bg-white/70 border border-dom-gold/20 rounded-2xl p-5 md:rounded-2xl">
        <h4 class="font-messiri text-[1.1rem] md:text-2xl text-dom-graphite mb-2 font-semibold md:font-normal">
          {item.title}
        </h4>
        <p class="font-montserrat text-sm text-dom-graphite/78 leading-[1.7] md:leading-normal">{item.description}</p>
      </div>
    ))}
  </div>
</article>
