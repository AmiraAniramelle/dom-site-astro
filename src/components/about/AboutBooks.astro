---
/**
 * Блок 8: Книги автора (about-sections/08-books.md, source-DOM ~6351–6382)
 */
interface Book {
  title: string;
  description: string;
  cover: string;
  url?: string;
  coverLayout?: 'default' | 'library';
}

interface Props {
  title: string;
  books: Book[];
  eyebrow?: string;
  intro?: string;
  cta?: { text: string; url: string };
}

const { title, books, eyebrow, intro, cta } = Astro.props;
---

<article class="about-light-card rounded-2xl p-8 md:p-10">
  {eyebrow ? (
    <p
      class="font-montserrat text-[11px] uppercase tracking-[0.12em] text-dom-goldDark mb-2 md:mb-3 block text-center md:text-left"
    >
      {eyebrow}
    </p>
  ) : null}
  <h2
    class="font-messiri text-dom-graphite mb-4 md:mb-6 text-[clamp(1.5rem,7vw,2rem)] md:text-4xl lg:text-5xl text-center md:text-left leading-tight"
  >
    {title}
  </h2>
  {intro ? (
    <p
      class="font-montserrat text-sm md:text-base lg:text-lg text-dom-graphite leading-relaxed mb-6 md:mb-10 text-left"
    >
      {intro}
    </p>
  ) : null}
  <div class="flex flex-col gap-4 md:grid md:grid-cols-2 lg:grid-cols-3 md:gap-8 mb-6 md:mb-10">
    {books.map((book) => {
      const isLibrary = book.coverLayout === 'library';
      const wrapClassMd = isLibrary
        ? 'rounded-xl bg-dom-beige/40 p-3 mb-3 min-h-[248px] flex items-center justify-center'
        : 'rounded-xl bg-dom-beige/40 p-3 mb-3';
      const imgClassMd = isLibrary
        ? 'w-full max-w-[210px] h-auto object-contain'
        : 'w-full max-w-[180px] mx-auto h-auto object-contain';
      const coverSrc = encodeURI(book.cover);
      const cardBody = (
        <>
          <div class="about-book-cover-wrap mb-3 md:mb-0">
            <div class="md:hidden w-full">
              <img
                src={coverSrc}
                alt={book.title}
                class="w-full max-h-[200px] object-cover rounded-xl"
                width={isLibrary ? 210 : 180}
                height={280}
                loading="lazy"
              />
            </div>
            <div class={`hidden md:block ${wrapClassMd}`}>
              <img
                src={coverSrc}
                alt={book.title}
                class={imgClassMd}
                width={isLibrary ? 210 : 180}
                height={280}
                loading="lazy"
              />
            </div>
          </div>
          <h3 class="font-messiri text-xl md:text-2xl text-dom-graphite mb-1">{book.title}</h3>
          <p class="font-montserrat text-sm md:text-base text-dom-graphite leading-relaxed">{book.description}</p>
        </>
      );
      return (
        <div
          class="about-book-row bg-white rounded-2xl border border-dom-gold/25 p-5 md:p-8 shadow-[0_10px_24px_rgba(126,91,35,0.1)]"
        >
          {book.url ? (
            <a href={book.url} class="block no-underline text-inherit hover:opacity-95 transition-opacity">
              {cardBody}
            </a>
          ) : (
            cardBody
          )}
        </div>
      );
    })}
  </div>
  {cta ? (
    <a href={cta.url} class="dom-btn-secondary w-full md:w-auto">
      {cta.text}
    </a>
  ) : null}
</article>
