---
/**
 * Блок 6: Экосистема DOM (about-sections/06-ecosystem.md, source-DOM ~6301–6329)
 * Спека: фото слева, заголовок, описание, список. Галерея из 5 фото — как в оригинале.
 */
interface Props {
  title: string;
  description: string;
  items: string[];
  image: { src: string; alt: string; width?: number; height?: number };
  eyebrow?: string;
  cta?: { text: string; url: string };
  gallery?: Array<{ src: string; alt: string; imgClass?: string }>;
}

const { title, description, items, image, eyebrow, cta, gallery } = Astro.props;
const imgW = image.width ?? 900;
const imgH = image.height ?? 1200;
const imgSrc = encodeURI(image.src);
---

<article class="about-light-card rounded-[2.2rem] p-7 md:p-10">
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-7 lg:gap-10 items-center">
    <div class="lg:col-span-5 w-full mb-4 md:mb-0">
      <div
        class="rounded-xl md:rounded-2xl overflow-hidden border border-dom-gold/25 h-[220px] sm:h-[280px] md:h-[320px] lg:h-[360px]"
      >
        <img
          src={imgSrc}
          alt={image.alt}
          class="w-full h-full object-cover object-center"
          width={imgW}
          height={imgH}
          loading="lazy"
        />
      </div>
    </div>
    <div class="lg:col-span-7">
      {eyebrow ? (
        <p
          class="font-montserrat text-[10px] md:text-[11px] uppercase tracking-[0.12em] text-dom-goldDark mb-3 text-center md:text-left"
        >
          {eyebrow}
        </p>
      ) : null}
      <h2
        class="font-messiri text-dom-graphite mb-4 text-[clamp(1.4rem,6vw,1.8rem)] md:text-5xl lg:text-6xl text-center md:text-left"
      >
        {title}
      </h2>
      <p
        class="font-montserrat text-sm md:text-lg text-dom-graphite/78 leading-[1.7] md:leading-relaxed mb-6 text-left"
      >
        {description}
      </p>
      {items.length > 0 ? (
        <ul
          class="font-montserrat text-sm md:text-base text-dom-graphite/78 leading-[1.7] md:leading-relaxed space-y-2 list-disc pl-5 mb-6 text-left"
        >
          {items.map((line) => (
            <li>{line}</li>
          ))}
        </ul>
      ) : null}
      {cta ? (
        <a
          href={cta.url}
          class="inline-flex w-full md:w-auto justify-center px-9 py-3 border border-dom-graphite/35 text-dom-graphite rounded-full hover:bg-dom-graphite hover:text-white transition font-montserrat font-semibold no-underline"
        >
          {cta.text}
        </a>
      ) : null}
    </div>
  </div>

  {gallery && gallery.length > 0 ? (
    <div class="mt-8 grid grid-cols-2 md:grid-cols-5 gap-3">
      {gallery.map((g) => (
        <div
          class="about-eco-gallery-cell rounded-xl md:rounded-2xl overflow-hidden border border-dom-gold/25 h-[160px] md:h-[220px]"
        >
          <img
            src={encodeURI(g.src)}
            alt={g.alt}
            class:list={['w-full h-full object-cover', g.imgClass ?? 'object-center']}
            width="400"
            height="300"
            loading="lazy"
          />
        </div>
      ))}
    </div>
  ) : null}
</article>
