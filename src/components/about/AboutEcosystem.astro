---
/**
 * Блок «Основатель экосистемы DOM»: центрированный текст + полоса из 5 карточек (макет /ru/about/).
 * Без крупного фото слева — портрет и смыслы в галерее.
 */
interface Props {
  title: string;
  titleLine2?: string;
  description: string;
  items: string[];
  image?: { src: string; alt: string; width?: number; height?: number };
  cta?: { text: string; url: string };
  gallery?: Array<{ src: string; alt: string; imgClass?: string }>;
}

const { title, titleLine2, description, items, image, cta, gallery } = Astro.props;
const hasGallery = Boolean(gallery && gallery.length > 0);
const imgW = image?.width ?? 900;
const imgH = image?.height ?? 1200;
const imgSrc = image ? encodeURI(image.src) : '';
---

{
  hasGallery ? (
    <article class="about-light-card about-ecosystem-founder rounded-2xl p-8 md:p-10 lg:p-12">
      <div class="max-w-[36rem] lg:max-w-[40rem] mx-auto text-center">
        <h2
          class="font-messiri text-dom-graphite uppercase tracking-[0.04em] mb-4 md:mb-6 text-[clamp(1.5rem,7vw,2rem)] md:text-4xl lg:text-5xl leading-tight"
        >
          <span class="block">{title}</span>
          {titleLine2 ? <span class="block mt-1 md:mt-2">{titleLine2}</span> : null}
        </h2>
        <p
          class="font-montserrat text-sm md:text-base lg:text-lg text-dom-graphite leading-relaxed mb-6 md:mb-8 text-center max-w-[36rem] mx-auto"
        >
          {description}
        </p>
        {items.length > 0 ? (
          <ul class="font-montserrat text-sm text-dom-graphite leading-relaxed space-y-2 list-disc pl-5 mb-6 text-left max-w-prose mx-auto">
            {items.map((line) => (
              <li>{line}</li>
            ))}
          </ul>
        ) : null}
        {cta ? (
          <a href={cta.url} class="dom-btn-secondary w-full sm:w-auto">
            {cta.text}
          </a>
        ) : null}
      </div>

      <div
        class="about-ecosystem-founder-gallery mt-8 md:mt-10 flex gap-3 md:gap-8 overflow-x-auto pb-1 snap-x snap-mandatory md:overflow-visible md:grid md:grid-cols-5 [-webkit-overflow-scrolling:touch]"
        role="list"
      >
        {gallery!.map((g) => (
          <div
            class="about-ecosystem-founder-gallery-cell flex-none w-[44%] sm:w-[30%] md:w-auto snap-center rounded-xl md:rounded-2xl overflow-hidden border border-dom-gold/20 h-[min(200px,52vw)] sm:h-[210px] md:h-[220px] lg:h-[240px]"
            role="listitem"
          >
            <img
              src={encodeURI(g.src)}
              alt={g.alt}
              class:list={['w-full h-full object-cover', g.imgClass ?? 'object-center']}
              width="400"
              height="500"
              loading="lazy"
            />
          </div>
        ))}
      </div>
    </article>
  ) : (
    <article class="about-light-card rounded-2xl p-8 md:p-10">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-center">
        {image ? (
          <div class="lg:col-span-5 w-full mb-4 md:mb-0">
            <div class="rounded-xl md:rounded-2xl overflow-hidden border border-dom-gold/25 h-[220px] sm:h-[280px] md:h-[320px] lg:h-[360px]">
              <img
                src={imgSrc}
                alt={image.alt}
                class="w-full h-full object-cover object-center"
                width={imgW}
                height={imgH}
                loading="lazy"
              />
            </div>
          </div>
        ) : null}
        <div class:list={['lg:col-span-7', !image && 'lg:col-span-12']}>
          <h2
            class="font-messiri text-dom-graphite mb-4 md:mb-6 text-[clamp(1.5rem,7vw,2rem)] md:text-4xl lg:text-5xl text-center md:text-left leading-tight"
          >
            {title}
            {titleLine2 ? (
              <>
                <br />
                {titleLine2}
              </>
            ) : null}
          </h2>
          <p class="font-montserrat text-sm md:text-base lg:text-lg text-dom-graphite leading-relaxed mb-6 text-left">
            {description}
          </p>
          {items.length > 0 ? (
            <ul class="font-montserrat text-sm md:text-base text-dom-graphite leading-relaxed space-y-2 list-disc pl-5 mb-6 text-left">
              {items.map((line) => (
                <li>{line}</li>
              ))}
            </ul>
          ) : null}
          {cta ? (
            <a href={cta.url} class="dom-btn-secondary w-full md:w-auto">
              {cta.text}
            </a>
          ) : null}
        </div>
      </div>
    </article>
  )
}
