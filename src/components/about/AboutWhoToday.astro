---
/**
 * Блок 2: Кто она сегодня (about-sections/02-who-today.md, source-DOM ~6228–6240)
 */
interface Props {
  eyebrow: string;
  title: string;
  paragraphs: string[];
}

const { eyebrow, title, paragraphs } = Astro.props;
---

<article class="about-light-card rounded-[2.2rem] p-7 md:p-9">
  <p
    class="font-montserrat text-[10px] md:text-[11px] uppercase tracking-[0.12em] text-dom-goldDark mb-3 text-center md:text-left"
  >
    {eyebrow}
  </p>
  <h2
    class="font-messiri text-dom-graphite mb-3 md:mb-6 text-[clamp(1.4rem,6vw,1.8rem)] md:text-4xl text-center md:text-left"
  >
    {title}
  </h2>
  {paragraphs.map((text, i) => (
    <p
      class:list={[
        'font-montserrat text-sm md:text-base text-dom-graphite/78 leading-[1.7] md:leading-relaxed text-left',
        i < paragraphs.length - 1 ? 'mb-4' : '',
      ]}
    >
      {text}
    </p>
  ))}
</article>
