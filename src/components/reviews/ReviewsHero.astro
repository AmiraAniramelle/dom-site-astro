---
/**
 * Блок 1: заголовок страницы «Отзывы»
 * @see reviews-sections/01-reviews-hero.md
 */
interface Props {
  eyebrow: string;
  title: string;
  subtitle: string;
}

const { eyebrow, title, subtitle } = Astro.props;
---

<div class="reviews-page-hero text-center mb-14">
  <p
    class="text-dom-goldDark font-bold tracking-widest uppercase text-sm mb-3 block font-montserrat"
  >
    {eyebrow}
  </p>
  <h1 class="font-messiri text-5xl md:text-6xl text-dom-graphite mb-6">
    {title}
  </h1>
  <div class="w-20 h-1 bg-dom-gold mx-auto mb-8" aria-hidden="true"></div>
  <p class="text-dom-graphite/70 text-lg max-w-2xl mx-auto font-montserrat">
    {subtitle}
  </p>
</div>
