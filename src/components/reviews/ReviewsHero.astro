---
/**
 * Блок 1: заголовок страницы «Отзывы»
 * @see reviews-sections/01-reviews-hero.md
 */
interface Props {
  eyebrow: string;
  title: string;
  subtitle: string;
}

const { eyebrow, title, subtitle } = Astro.props;
---

<div class="reviews-page-hero text-center mb-14 max-md:mb-8">
  <p
    class="text-dom-gold-dark font-bold tracking-widest uppercase text-sm mb-3 block font-montserrat max-md:text-[11px] max-md:text-center"
  >
    {eyebrow}
  </p>
  <h1 class="hero-title text-dom-graphite mb-6 max-md:mb-4 max-md:text-center max-md:break-words">
    {title}
  </h1>
  <div
    class="w-20 max-md:w-16 h-1 bg-dom-gold mx-auto mb-8 max-md:mb-5"
    aria-hidden="true"
  >
  </div>
  <p
    class="text-dom-graphite/70 text-lg max-w-2xl mx-auto font-montserrat max-md:text-sm max-md:text-center max-md:break-words"
  >
    {subtitle}
  </p>
</div>
