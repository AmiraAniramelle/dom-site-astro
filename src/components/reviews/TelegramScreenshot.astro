---
/**
 * Карточка скриншота из Telegram — reviews-sections/05-telegram-reviews.md
 */
interface Props {
  screenshot: string;
  title: string;
  telegramLink?: string;
}

const { screenshot, title, telegramLink } = Astro.props;
const imgSrc = encodeURI(screenshot);
const shotAlt = `Скриншот отзыва из Telegram: ${title}`;
---

<article class="telegram-shot max-md:rounded-xl overflow-hidden">
  <button
    type="button"
    class="telegram-shot-open block w-full border-0 bg-transparent p-0 cursor-pointer text-left focus:outline-none focus-visible:ring-2 focus-visible:ring-dom-gold/50 focus-visible:ring-offset-2"
    data-telegram-shot-open
    data-telegram-img={imgSrc}
    data-telegram-alt={shotAlt}
    data-telegram-link={telegramLink ?? ''}
    aria-haspopup="dialog"
  >
    <img
      src={imgSrc}
      alt={shotAlt}
      class="telegram-shot-img w-full max-md:rounded-xl"
      width="320"
      height="250"
      loading="lazy"
    />
  </button>
  <div class="p-4 max-md:p-2">
    <p
      class="font-montserrat text-xs max-md:text-[10px] max-md:leading-tight uppercase tracking-[0.12em] text-dom-goldDark mb-0 max-md:normal-case max-md:tracking-wide"
    >
      {title}
    </p>
    {
      telegramLink ? (
        <a
          href={telegramLink}
          target="_blank"
          rel="noopener noreferrer"
          class="font-montserrat text-xs text-dom-graphite/80 underline underline-offset-2 mt-2 inline-block hover:text-dom-graphite"
        >
          Открыть в Telegram
        </a>
      ) : null
    }
  </div>
</article>
