---
import { Image } from 'astro:assets';
import logo from '../assets/images/dom-logo-symbol-gold.png';
import { navItems, getMobileNavLinks, langSwitcher, type NavItem } from '../data/navbar';

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

function isItemActive(item: NavItem): boolean {
  const p = item.url.replace(/\/$/, '') || '/';
  if (currentPath === p || (p !== '/ru' && currentPath.startsWith(p + '/'))) return true;
  if (item.children) {
    return item.children.some((c) => {
      const cp = c.url.replace(/\/$/, '') || '/';
      if (cp === '/ru') return currentPath === '/ru';
      return currentPath === cp || currentPath.startsWith(cp + '/');
    });
  }
  return false;
}

const mobileLinks = getMobileNavLinks();
const isRu = currentPath.startsWith('/ru') || currentPath === '/';
---

<nav class="fixed w-full z-50 top-0 left-0 right-0 bg-dom-graphite/95 transition-all duration-300 border-0 shadow-none" id="navbar" aria-label="Главная навигация" style="border: none; box-shadow: none;">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-24 md:h-28">
      <a href="/ru/" class="flex-shrink-0 flex items-center group" aria-label="DOM — Главная">
        <Image src={logo} alt="Логотип DOM" class="brand-logo" width={384} height={384} />
      </a>

      <div class="hidden md:flex items-center gap-5">
        <div class="ml-6 lg:ml-10 flex items-baseline space-x-2 lg:space-x-6">
          {navItems.map((item) => (
            item.children && item.children.length > 0 ? (
              <div class="relative group/nav">
                <a
                  href={item.url}
                  class={`nav-link px-2 py-2 rounded-md text-sm font-normal transition-colors ${isItemActive(item) ? 'nav-link-active' : 'text-dom-beige hover:text-dom-gold'}`}
                  aria-haspopup="true"
                  aria-expanded="false"
                >
                  {item.title}
                </a>
                <div class="blog-nav-dropdown-menu opacity-0 invisible group-hover/nav:opacity-100 group-hover/nav:visible transition-all absolute left-1/2 -translate-x-1/2 mt-1">
                  {item.children.map((child) => (
                    <a href={child.url} class="blog-nav-dropdown-item block" aria-label={child.title}>{child.title}</a>
                  ))}
                </div>
              </div>
            ) : (
              <a
                href={item.url}
                class={`nav-link px-2 py-2 rounded-md text-sm font-normal transition-colors ${isItemActive(item) ? 'nav-link-active' : 'text-dom-beige hover:text-dom-gold'}`}
              >
                {item.title}
              </a>
            )
          ))}
        </div>
        <div class="lang-switch" role="group" aria-label="Выбор языка">
          <a
            href={langSwitcher.current.href}
            class={`lang-switch-link ${isRu ? 'active' : ''}`}
            aria-current={isRu ? 'page' : undefined}
            aria-label="Русский"
          >
            {langSwitcher.current.label}
          </a>
          <a href={langSwitcher.other.href} class={`lang-switch-link ${!isRu ? 'active' : ''}`} aria-label="English">
            {langSwitcher.other.label}
          </a>
        </div>
      </div>

      <div class="md:hidden">
        <button id="mobile-menu-btn" type="button" class="text-dom-gold hover:text-white focus:outline-none p-2" aria-label="Меню" aria-expanded="false" aria-haspopup="true">
          <span class="text-2xl">☰</span>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-dom-graphite border-t border-dom-gold/20">
    <div class="px-2 pt-2 pb-3 space-y-1 sm:px-3">
      {mobileLinks.map((link) => (
        <a href={link.url} class="block text-dom-beige hover:text-dom-gold px-3 py-2 rounded-md text-base font-normal">
          {link.title}
        </a>
      ))}
      <div class="pt-3 mt-2 border-t border-dom-gold/25">
        <p class="px-3 pb-2 text-[11px] uppercase tracking-[0.14em] text-dom-gold/80 font-semibold">Язык</p>
        <div class="lang-switch" aria-label="Переключение языка (мобильное)">
          <a href={langSwitcher.current.href} class={`lang-switch-link ${isRu ? 'active' : ''}`}>{langSwitcher.current.label}</a>
          <a href={langSwitcher.other.href} class={`lang-switch-link ${!isRu ? 'active' : ''}`}>{langSwitcher.other.label}</a>
        </div>
      </div>
    </div>
  </div>
</nav>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    if (!menu) return;
    menu.classList.toggle('hidden');
    const isOpen = !menu.classList.contains('hidden');
    btn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
  });
</script>
