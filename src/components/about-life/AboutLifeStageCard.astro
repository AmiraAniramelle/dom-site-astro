---
/**
 * Содержимое одного этапа (timeline-оболочка — в about-life.astro)
 */
interface Props {
  eyebrow: string;
  title: string;
  description: string;
}

const { eyebrow, title, description } = Astro.props;
---

<div class="about-life-stage-card-inner lg:text-center">
  <p
    class="font-montserrat text-[11px] uppercase tracking-[0.12em] text-dom-goldDark mb-2"
  >
    {eyebrow}
  </p>
  <h3 class="font-messiri text-xl md:text-2xl text-dom-graphite mb-3">{title}</h3>
  <p class="font-montserrat text-base text-dom-graphite/80 leading-relaxed">
    {description}
  </p>
</div>
