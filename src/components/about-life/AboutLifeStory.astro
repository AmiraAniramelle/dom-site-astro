---
/**
 * Блок 2: фото + текст — без белой карточки, сетка 12 колонок (about-life-sections)
 */
interface Props {
  title: string;
  paragraphs: string[];
  portrait: { src: string; alt: string };
}

const { title, paragraphs, portrait } = Astro.props;
---

<div
  class="grid grid-cols-1 lg:grid-cols-12 gap-8 mb-12 lg:items-center"
>
  <div class="lg:col-span-5 flex items-center">
    <div class="w-full overflow-hidden rounded-[2rem] border border-dom-gold/25">
      <img
        src={portrait.src}
        alt={portrait.alt}
        class="w-full h-full min-h-[280px] lg:min-h-[360px] object-cover object-top"
        width="800"
        height="1000"
        loading="lazy"
        decoding="async"
      />
    </div>
  </div>
  <div class="lg:col-span-7 flex items-center">
    <div class="w-full">
      <h2 class="font-messiri text-3xl md:text-4xl text-dom-graphite mb-5">
        {title}
      </h2>
      {
        paragraphs.map((text) => (
          <p class="font-montserrat text-base md:text-lg text-dom-graphite/85 leading-relaxed mb-4 last:mb-0">
            {text}
          </p>
        ))
      }
    </div>
  </div>
</div>
