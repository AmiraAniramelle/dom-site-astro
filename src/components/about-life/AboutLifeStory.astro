---
/**
 * Блок 2: От личного опыта к системе DOM (about-life-sections/02-story.md)
 */
interface Props {
  title: string;
  paragraphs: string[];
  portrait: { src: string; alt: string };
}

const { title, paragraphs, portrait } = Astro.props;
---

<div class="grid grid-cols-1 lg:grid-cols-12 gap-8 mb-12">
  <div class="lg:col-span-4">
    <div
      class="rounded-[2rem] overflow-hidden border border-dom-gold/30 shadow-[0_22px_48px_rgba(126,91,35,0.16)]"
    >
      <img
        src={portrait.src}
        alt={portrait.alt}
        class="w-full h-full object-cover object-top"
        width="800"
        height="1000"
        loading="lazy"
      />
    </div>
  </div>
  <div class="lg:col-span-8">
    <div
      class="p-8 rounded-[2rem] border border-dom-gold/25 bg-white/90 shadow-[0_20px_42px_rgba(126,91,35,0.12)]"
    >
      <h2 class="font-messiri text-3xl text-dom-graphite mb-4">{title}</h2>
      {paragraphs.map((text) => (
        <p class="font-montserrat text-base text-dom-graphite/82 leading-relaxed mb-4 last:mb-0">
          {text}
        </p>
      ))}
    </div>
  </div>
</div>
