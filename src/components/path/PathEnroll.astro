---
/**
 * Блок 4 «Занять место в программе» — source-DOM.html 5869–5912 (классы 1:1, форма → GetCourse)
 */
interface Props {
  eyebrow: string;
  titleLine1: string;
  titleLine2: string;
  description: string;
  formDisclaimer: string;
}

const { eyebrow, titleLine1, titleLine2, description, formDisclaimer } = Astro.props;
---

<div
  class="path-enroll fade-in max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-8 md:pt-10 pb-12 md:pb-16"
  role="region"
  aria-labelledby="path-enroll-heading"
>
  <div
    class="bg-white rounded-3xl border border-dom-gold/25 p-7 md:p-10 lg:p-12 shadow-[0_20px_44px_rgba(126,91,35,0.16)]"
  >
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-start">
      <div class="lg:col-span-5">
        <p class="path-map-eyebrow font-montserrat text-[11px] uppercase tracking-[0.12em] text-dom-goldDark mb-2">{eyebrow}</p>
        <h3
          id="path-enroll-heading"
          class="font-messiri text-4xl md:text-5xl leading-[1.08] text-dom-graphite mb-5"
        >
          {titleLine1}
          <br />
          {titleLine2}
        </h3>
        <p class="font-montserrat text-lg leading-relaxed text-dom-graphite/65 max-w-md">
          {description}
        </p>
      </div>
      <div class="lg:col-span-7 w-full min-w-0">
        <div
          class="path-enroll-form-wrap path-enroll-getcourse"
          aria-label="Форма заявки"
          id="getcourse-widget-container-path"
        >
          <div class="path-enroll-getcourse-placeholder" id="getcourse-placeholder-path">
            <p class="text-sm text-dom-graphite/70 font-montserrat">Загрузка формы…</p>
          </div>
          <script
            id="path-getcourse-widget-script"
            src="https://khefors.ru/pl/lite/widget/script?id=1575472"
            defer
          ></script>
          <script is:inline>
            (function () {
              function hidePlaceholder() {
                var el = document.getElementById('getcourse-placeholder-path');
                if (el) el.style.display = 'none';
              }
              if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', function check() {
                  setTimeout(function () {
                    var container = document.getElementById('getcourse-widget-container-path');
                    if (container && container.querySelector('iframe')) hidePlaceholder();
                  }, 1500);
                });
              } else {
                setTimeout(function () {
                  var container = document.getElementById('getcourse-widget-container-path');
                  if (container && container.querySelector('iframe')) hidePlaceholder();
                }, 1500);
              }
              setInterval(function () {
                var container = document.getElementById('getcourse-widget-container-path');
                if (container && container.querySelector('iframe')) hidePlaceholder();
              }, 800);
            })();
          </script>
        </div>
        <p class="path-enroll-note mt-3 font-montserrat text-xs text-dom-graphite/60">{formDisclaimer}</p>
      </div>
    </div>
  </div>
</div>
