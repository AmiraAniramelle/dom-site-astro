---
/**
 * «Мобильное приложение DOM / IT BRAIN» — компактная карточка как у остальных продуктов «Душа» (без QR в карточке).
 */
import { appBlock } from '../../data/footer';

export interface Props {
  gridItemClass?: string;
  theme?: 'light' | 'dark';
  rootClass: string;
  badge: { text: string; class: string };
  title: string;
  titleClass: string;
  subtitle: string;
  subtitleClass: string;
  paragraphs: [string, string];
  paragraphClass: string;
  iconSrc: string;
  iconAlt: string;
  qrHint: string;
  qrHintClass: string;
  appStoreLabel: string;
  googlePlayLabel: string;
  primaryCtaClass: string;
  outlineCtaClass: string;
  aboutHref: string;
  appBrandLine1?: string;
  appBrandLine2?: string;
}

const {
  gridItemClass = '',
  theme,
  rootClass,
  badge,
  title,
  titleClass,
  subtitle,
  subtitleClass,
  paragraphs,
  paragraphClass,
  iconSrc,
  iconAlt,
  aboutHref,
} = Astro.props;

const [apple, google] = appBlock.stores;
const shell =
  'bg-white/10 backdrop-blur-md p-8 rounded-2xl border border-dom-gold/30 relative overflow-hidden dom-dark-card-glow flex flex-col h-full min-h-0';
const heroImgClass =
  'h-48 w-full object-cover object-center rounded-xl shrink-0 mb-4 relative z-[1]';
const storeBtn =
  'flex-1 min-w-[6.5rem] text-center py-2.5 px-2 text-[10px] sm:text-[11px] font-montserrat font-bold uppercase tracking-wider border border-dom-gold/45 text-dom-beige rounded hover:bg-white/10 transition no-underline';
const bodyText = `${paragraphs[0]} ${paragraphs[1]}`;
---

<div class:list={[gridItemClass, 'flex flex-col h-full w-full min-h-0']} data-path-direction-theme={theme}>
  <div class:list={[shell, rootClass]}>
    <div class={badge.class}>{badge.text}</div>
    <img src={iconSrc} alt={iconAlt} class={heroImgClass} loading="lazy" decoding="async" />
    <h3 class:list={[titleClass, 'shrink-0 relative z-[1]']}>{title}</h3>
    <p class:list={[subtitleClass, 'shrink-0 relative z-[1]']}>{subtitle}</p>
    <p class:list={[paragraphClass, 'flex-grow relative z-[1] min-h-0 mb-0']}>{bodyText}</p>
    <div class="mt-auto pt-4 space-y-3 shrink-0 relative z-[1] w-full">
      <a
        href={apple.href}
        target="_blank"
        rel="noopener noreferrer"
        class="block w-full py-3 px-4 bg-dom-gold text-white font-bold rounded hover:bg-dom-goldDark transition shadow-lg shadow-dom-gold/25 text-sm text-center no-underline"
      >
        Скачать в App Store
      </a>
      <a
        href={google.href}
        target="_blank"
        rel="noopener noreferrer"
        class="block w-full py-3 px-4 border border-dom-gold/50 text-dom-beige font-bold rounded hover:bg-white/10 transition text-sm text-center no-underline"
      >
        Скачать в Google Play
      </a>
      <a
        href={aboutHref}
        class="block w-full py-2.5 text-center text-[11px] font-montserrat uppercase tracking-widest text-[#c5a059] hover:text-dom-gold no-underline"
      >
        О приложении и IT BRAIN →
      </a>
    </div>
  </div>
</div>
