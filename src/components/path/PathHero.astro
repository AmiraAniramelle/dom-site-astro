---
/**
 * Блок 1: заголовок страницы «Карта Пути» (source-DOM.html ~5784–5793)
 */
interface Props {
  title: string;
  subtitle: string;
}

const { title, subtitle } = Astro.props;
---

<section
  class="path-hero bg-dom-beige relative overflow-hidden futuristic-grid pt-12 pb-6 md:pt-20 md:pb-10"
  aria-labelledby="path-hero-heading"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="text-center fade-in">
      <img
        src="/images/shared/dom-symbol-gold.svg"
        alt=""
        class="w-12 h-12 mx-auto mb-5 opacity-90"
        width="48"
        height="48"
        loading="eager"
        aria-hidden="true"
      />
      <h1
        id="path-hero-heading"
        class="path-hero-title font-messiri text-dom-graphite mb-6 text-center text-[clamp(1.6rem,7vw,2.2rem)] md:text-5xl lg:text-6xl"
      >
        {title}
      </h1>
      <div class="w-20 h-1 bg-dom-gold mx-auto mb-8" aria-hidden="true"></div>
      <p
        class="path-hero-sub text-dom-graphite/80 max-w-3xl mx-auto font-montserrat leading-relaxed font-light text-center text-sm md:text-xl"
      >
        {subtitle}
      </p>
    </div>
  </div>
</section>
