---
/**
 * «Источник внутренней радости» — компактная карточка в стиле остальных продуктов направления «Душа».
 */
export interface Props {
  gridItemClass?: string;
  theme?: 'light' | 'dark';
  rootClass: string;
  badge: { text: string; class: string };
  title: string;
  titleClass: string;
  description: string;
  descriptionClass: string;
  accessStrong: string;
  accessText: string;
  accessRowClass: string;
  image: string;
  imageAlt: string;
  visualFooterText: string;
  visualIconSrc: string;
  visualIconAlt: string;
  primaryCta: { text: string; href: string; class: string };
  outlineCtaClass: string;
  appStoreHref: string;
  googlePlayHref: string;
}

const {
  gridItemClass = '',
  theme,
  rootClass,
  badge,
  title,
  titleClass,
  description,
  descriptionClass,
  accessStrong,
  accessText,
  accessRowClass,
  image,
  imageAlt,
  primaryCta,
  appStoreHref,
  googlePlayHref,
} = Astro.props;

const shell =
  'bg-white/10 backdrop-blur-md p-8 rounded-2xl border border-dom-gold/30 relative overflow-hidden dom-dark-card-glow flex flex-col h-full min-h-0';
const imgClass = 'h-48 w-full object-cover rounded-xl shrink-0 mb-4 relative z-[1]';
const storeBtn =
  'flex-1 min-w-[6.5rem] text-center py-2.5 px-2 text-[10px] sm:text-[11px] font-montserrat font-bold uppercase tracking-wider border border-dom-gold/45 text-dom-beige rounded hover:bg-white/10 transition no-underline';
---

<div class:list={[gridItemClass, 'flex flex-col h-full w-full min-h-0']} data-path-direction-theme={theme}>
  <div class:list={[shell, rootClass]}>
    <div class={badge.class}>{badge.text}</div>
    <img src={image} alt={imageAlt} class={imgClass} loading="lazy" decoding="async" />
    <h3 class:list={[titleClass, 'shrink-0 relative z-[1]']}>{title}</h3>
    <p class:list={[descriptionClass, 'flex-grow relative z-[1] min-h-0']}>{description}</p>
    <p class:list={[accessRowClass, 'shrink-0 relative z-[1]']}>
      <span class="font-bold">{accessStrong}</span>{accessText}
    </p>
    <div class="mt-auto pt-4 space-y-3 shrink-0 relative z-[1] w-full">
      <a
        href={primaryCta.href}
        class="block w-full py-3 px-4 bg-dom-gold text-white font-bold rounded hover:bg-dom-goldDark transition shadow-lg shadow-dom-gold/25 text-sm text-center uppercase tracking-wide no-underline"
      >
        {primaryCta.text}
      </a>
      <div class="flex flex-wrap gap-2">
        <a href={appStoreHref} target="_blank" rel="noopener noreferrer" class={storeBtn}>App Store</a>
        <a href={googlePlayHref} target="_blank" rel="noopener noreferrer" class={storeBtn}>Google Play</a>
      </div>
    </div>
  </div>
</div>
