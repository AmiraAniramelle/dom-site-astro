---
interface Item {
  /** Не отображается в карточке (оставлено для совместимости данных) */
  letter?: string;
  name: string;
  description: string;
  url: string;
  hasBridge?: boolean;
  buttonText: string;
}

interface Props {
  eyebrow: string;
  title: string;
  subtitle: string;
  items: Item[];
}

const { eyebrow, title, subtitle, items } = Astro.props;

---

<div class="path-internal-house max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
  <div
    class="path-internal-house-card dom-dark-shell rounded-3xl p-8 md:p-12 lg:p-16 relative overflow-hidden shadow-2xl text-dom-beige border border-[rgba(217,179,114,0.32)]"
  >
    <div
      class="absolute bottom-0 right-0 -mb-20 -mr-20 w-96 h-96 bg-dom-gold rounded-full opacity-10 blur-3xl pointer-events-none"
      aria-hidden="true"
    ></div>
    <div class="relative z-10">
      <div class="path-internal-house-intro text-center mb-12">
        <span class="path-map-eyebrow block text-dom-goldDark font-bold tracking-widest uppercase text-sm mb-3 font-montserrat">{eyebrow}</span>
        <h2 class="font-messiri text-4xl md:text-5xl text-dom-gold mb-6 uppercase tracking-wide drop-shadow-sm">
          {title}
        </h2>
        <p class="max-w-3xl mx-auto font-montserrat text-lg leading-relaxed text-dom-beige/85">
          {subtitle}
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-10 max-w-5xl mx-auto">
        {items.map((item) => (
          <a
            href={item.url}
            class="bg-white/10 backdrop-blur-md p-5 md:p-10 rounded-2xl border border-dom-gold/30 hover:bg-white/15 hover:border-dom-gold/50 transition-all duration-300 flex flex-col items-center text-center group no-underline text-dom-beige"
          >
            <div
              class="w-14 h-14 rounded-full border border-dom-gold/50 flex items-center justify-center mb-8 transition-all group-hover:bg-dom-gold group-hover:border-dom-gold"
            >
              <span class="font-messiri text-xl text-dom-gold transition-all group-hover:text-white">{item.letter}</span>
            </div>
            {item.hasBridge ? (
              <h4
                class="path-internal-card-title font-messiri text-3xl mb-4 inline-flex flex-wrap items-center justify-center gap-2 text-dom-gold min-w-0 max-w-full text-center"
              >
                {item.name}
                <img
                  src="/images/shared/bridge-element.png"
                  alt=""
                  class="bridge-icon shrink-0"
                  width="20"
                  height="20"
                  loading="lazy"
                  aria-hidden="true"
                />
              </h4>
            ) : (
              <h4
                class="path-internal-card-title font-messiri text-2xl md:text-3xl text-dom-gold uppercase tracking-wider mb-3 min-w-0 max-w-full break-words"
              >
                {item.name}
              </h4>
            )}
            <p class="text-sm mb-5 font-montserrat leading-relaxed text-dom-beige/80 flex-grow min-w-0 w-full">{item.description}</p>
            <span class="self-stretch px-6 py-2 border border-dom-gold/45 text-dom-gold rounded hover:bg-dom-gold hover:text-white transition font-medium text-sm inline-block text-center">{item.buttonText}</span>
          </a>
        ))}
      </div>
    </div>
  </div>
</div>
