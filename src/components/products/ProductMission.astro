---
interface Props {
  mission: string;
  whyImportant: string;
}

const { mission, whyImportant } = Astro.props as Props;
---

<section class="mx-auto w-full max-w-5xl">
  <div class="grid grid-cols-1 gap-6 lg:grid-cols-2 lg:gap-8">
    <article
      class="product-mission-dark relative z-[1] isolate flex h-full flex-col overflow-hidden rounded-3xl border border-dom-gold/20 p-6 shadow-[0_18px_48px_rgba(24,20,16,0.35)] ring-1 ring-inset ring-white/[0.06] md:p-10 lg:p-12"
      style="background: linear-gradient(165deg, #3d3730 0%, #2a2520 55%, #221e1a 100%);"
    >
      <h3
        class="mb-5 font-messiri text-2xl leading-snug tracking-[0.04em] text-dom-gold md:mb-6 md:text-3xl"
      >
        Миссия проекта
      </h3>
      <p class="text-balance font-montserrat text-[15px] leading-relaxed text-dom-beige/85 md:text-base md:leading-[1.65]">
        {mission}
      </p>
    </article>

    <article class="product-light-card flex h-full flex-col rounded-3xl p-6 md:p-10 lg:p-12">
      <h3 class="mb-5 font-messiri text-2xl leading-snug tracking-tight text-dom-graphite md:mb-6 md:text-3xl">
        Почему это важно?
      </h3>
      <p class="text-balance font-montserrat text-[15px] leading-relaxed text-dom-graphite/80 md:text-base md:leading-[1.65]">
        {whyImportant}
      </p>
    </article>
  </div>
</section>
