---
/**
 * Двухколоночный блок «Формат» + «Результат после курса» — business-mission.
 */
import { dsBody, dsH2, dsH3 } from '../../data/ui/domTypography';

export type FormatIcon = 'target' | 'bulb' | 'chat';

export interface BmFormatResultsData {
  formatTitle: string;
  formatItems: Array<{ icon: FormatIcon; text: string }>;
  ctaText?: string;
  ctaHref?: string;
  resultsTitle: string;
  resultsItems: Array<{
    segments: Array<{ text?: string; gold?: string }>;
  }>;
}

interface Props {
  data: BmFormatResultsData;
}

const { data } = Astro.props;
const ctaText = data.ctaText?.trim() || 'ЗАНЯТЬ МЕСТО';
const ctaHref = data.ctaHref?.trim() || '#product-enroll-block';
---

<section>
  <div class="w-full">
    <div
      class="overflow-hidden rounded-[2rem] border border-dom-gold/22 bg-[linear-gradient(145deg,rgba(255,252,244,0.98),rgba(246,233,203,0.92))] px-4 py-6 md:px-5 md:py-8 lg:px-6 lg:py-10"
    >
      <div
        class="product-light-card rounded-2xl p-5 md:p-6 lg:p-8"
      >
        <div class="grid grid-cols-1 gap-8 lg:grid-cols-2 lg:items-start lg:gap-10">
          <!-- Формат -->
          <div class="flex flex-col">
            <h2 class:list={['mb-5 md:mb-6', dsH2]}>{data.formatTitle}</h2>
            <ul class="mb-6 flex flex-col gap-4 md:gap-5">
              {
                data.formatItems.map((row) => (
                  <li class="flex gap-4">
                    <span class="mt-0.5 flex h-10 w-10 flex-shrink-0 items-center justify-center text-dom-gold-dark md:h-11 md:w-11" aria-hidden="true">
                      {row.icon === 'target' && (
                        <svg class="h-9 w-9 md:h-10 md:w-10" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" stroke-width="1.4">
                          <circle cx="24" cy="24" r="14" />
                          <circle cx="24" cy="24" r="6" />
                          <circle cx="24" cy="24" r="2" fill="currentColor" stroke="none" />
                          <path d="M24 4v6M24 38v6M4 24h6M38 24h6" stroke-linecap="round" />
                          <path d="M34 14l-4 4" stroke-linecap="round" />
                        </svg>
                      )}
                      {row.icon === 'bulb' && (
                        <svg class="h-9 w-9 md:h-10 md:w-10" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" stroke-width="1.4">
                          <path d="M18 38h12v4a3 3 0 01-3 3h-6a3 3 0 01-3-3v-4z" stroke-linejoin="round" />
                          <path d="M16 38c-4-4-6-9-6-15a14 14 0 1128 0c0 6-2 11-6 15" stroke-linecap="round" stroke-linejoin="round" />
                          <path d="M20 22h8M24 18v8" stroke-linecap="round" />
                        </svg>
                      )}
                      {row.icon === 'chat' && (
                        <svg class="h-9 w-9 md:h-10 md:w-10" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" stroke-width="1.4">
                          <path d="M10 14a4 4 0 014-4h20a4 4 0 014 4v14a4 4 0 01-4 4H22l-8 6v-6h-4a4 4 0 01-4-4V14z" stroke-linejoin="round" />
                          <path d="M28 20h6M25 25h9" stroke-linecap="round" />
                          <circle cx="32" cy="32" r="6" fill="none" />
                          <path d="M32 29v6M29 32h6" stroke-linecap="round" />
                        </svg>
                      )}
                    </span>
                    <p class:list={['font-semibold uppercase leading-snug tracking-[0.06em] text-dom-graphite', dsBody]}>
                      {row.text}
                    </p>
                  </li>
                ))
              }
            </ul>
            <a href={ctaHref} class="dom-btn-primary mt-auto w-full text-center lg:w-auto lg:self-start">
              {ctaText}
            </a>
          </div>

          <!-- Результат -->
          <div class="rounded-2xl border border-dom-gold/15 bg-white p-5 shadow-[0_10px_36px_rgba(56,51,45,0.08)] md:p-6">
            <h3 class:list={['mb-5 md:mb-6', dsH3]}>
              {data.resultsTitle}
            </h3>
            <ul class="flex flex-col gap-4 md:gap-5">
              {
                data.resultsItems.map((item) => (
                  <li class="flex gap-3">
                    <span class="mt-0.5 flex-shrink-0 font-montserrat text-dom-gold-dark" aria-hidden="true">
                      ✓✓
                    </span>
                    <p class:list={['text-dom-graphite', dsBody]}>
                      {item.segments.map((seg) =>
                        'gold' in seg ? (
                          <span class="font-semibold text-dom-gold-dark">{seg.gold}</span>
                        ) : (
                          <span>{'text' in seg ? seg.text : ''}</span>
                        )
                      )}
                    </p>
                  </li>
                ))
              }
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
