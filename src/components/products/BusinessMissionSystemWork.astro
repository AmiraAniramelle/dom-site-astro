---
/**
 * «Это не мотивационный курс» + системная работа (4 карточки) — business-mission.
 */
import { dsBody, dsH2 } from '../../data/ui/domTypography';

export interface BmSystemWorkData {
  title: string;
  strikethroughItems: string[];
  subtitle: string;
  cards: Array<{ label: string; image?: string }>;
}

interface Props {
  data: BmSystemWorkData;
}

const { data } = Astro.props;
---

<section>
  <div class="w-full">
    <div
      class="overflow-hidden rounded-[2rem] border border-dom-gold/22 bg-[linear-gradient(145deg,rgba(255,252,244,0.98),rgba(246,233,203,0.92))] px-5 py-8 md:px-8 md:py-10 lg:px-10 lg:py-12"
    >
      <h2 class:list={['mx-auto mb-5 w-full text-center md:mb-7', dsH2]}>
        {data.title}
      </h2>

      <div
        class="mb-8 flex flex-wrap items-center justify-center gap-x-4 gap-y-2 md:gap-x-8 md:gap-y-3"
        role="presentation"
      >
        {
          data.strikethroughItems.map((phrase) => (
            <span
              class:list={['font-medium text-dom-graphite/80 line-through decoration-dom-gold/70 decoration-2', dsBody]}
            >
              {phrase}
            </span>
          ))
        }
      </div>

      <p class:list={['mb-8 text-center font-medium text-dom-graphite/85 md:mb-10', dsBody]}>
        {data.subtitle}
      </p>

      <div class="grid grid-cols-2 gap-3 md:gap-5 lg:grid-cols-4">
        {
          data.cards.map((card, i) => {
            const imageFirst = i % 2 === 0;
            const imgSrc = card.image?.trim();
            const mediaBlock = imgSrc ? (
              <div class="relative aspect-[4/3] w-full overflow-hidden bg-[rgba(246,233,203,0.45)]">
                <img
                  src={imgSrc}
                  alt={`Иллюстрация: ${card.label}`}
                  class="h-full w-full object-cover"
                  loading="lazy"
                  decoding="async"
                  width="400"
                  height="300"
                />
              </div>
            ) : (
              <div
                class="aspect-[4/3] w-full bg-gradient-to-br from-dom-gold/25 via-[rgba(246,233,203,0.6)] to-transparent"
                aria-hidden="true"
              />
            );

            const labelBlock = (
              <div class="flex flex-1 items-center justify-center bg-[rgba(255,252,244,0.95)] px-2 py-4 md:px-3 md:py-5">
                <p class="text-center font-montserrat text-[11px] font-semibold uppercase leading-snug tracking-[0.08em] text-dom-graphite md:text-xs">
                  {card.label}
                </p>
              </div>
            );

            return (
              <div class="flex min-h-0 flex-col divide-y divide-dom-gold/20 overflow-hidden rounded-2xl border border-dom-gold/25 bg-white/40 shadow-[0_8px_28px_rgba(126,91,35,0.1)]">
                {imageFirst ? (
                  <>
                    {mediaBlock}
                    {labelBlock}
                  </>
                ) : (
                  <>
                    {labelBlock}
                    {mediaBlock}
                  </>
                )}
              </div>
            );
          })
        }
      </div>
    </div>
  </div>
</section>
