---
interface Props {
  title: string;
  modulesCount: number;
  format: string;
  access: string;
}

const { title, modulesCount, format, access } = Astro.props as Props;
---

<section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 mb-8 md:mb-16">
  <div class="product-video-shell mb-4 rounded-2xl border border-dom-gold/30 bg-dom-graphite p-6 md:p-8 shadow-[0_14px_32px_rgba(23,18,12,0.35)]">
    <div class="product-video-inner rounded-xl border border-dom-gold/25 bg-[linear-gradient(155deg,rgba(71,54,30,0.36),rgba(37,28,19,0.62))] p-6 md:p-8">
      <span class="product-video-chip inline-block mb-4 rounded-full border border-dom-gold/45 bg-dom-gold/20 px-4 py-1.5 font-montserrat text-[11px] font-semibold uppercase tracking-[0.12em] text-dom-beige">
        Видео-презентация программы
      </span>
      <h2 class="font-messiri text-3xl md:text-5xl text-dom-beige leading-tight">
        {title}
      </h2>
    </div>
  </div>

  <div class="product-meta-strip rounded-2xl border border-dom-gold/25 bg-[linear-gradient(145deg,rgba(255,252,244,0.98),rgba(246,233,203,0.92))] p-4 md:p-6 shadow-[0_10px_24px_rgba(126,91,35,0.12)]">
    <div class="flex flex-col md:flex-row md:items-center gap-4 md:gap-6">
      <div class="flex-1 text-center">
        <p class="font-montserrat text-[11px] uppercase tracking-[0.12em] text-dom-goldDark mb-1">Формат</p>
        <p class="font-montserrat text-sm md:text-base text-dom-graphite/85">{format}</p>
      </div>
      <span class="hidden md:block w-px h-12 bg-dom-gold/35"></span>
      <div class="flex-1 text-center">
        <p class="font-montserrat text-[11px] uppercase tracking-[0.12em] text-dom-goldDark mb-1">Материалы</p>
        <p class="font-montserrat text-sm md:text-base text-dom-graphite/85">{modulesCount} модулей</p>
      </div>
      <span class="hidden md:block w-px h-12 bg-dom-gold/35"></span>
      <div class="flex-1 text-center">
        <p class="font-montserrat text-[11px] uppercase tracking-[0.12em] text-dom-goldDark mb-1">Доступ</p>
        <p class="font-montserrat text-sm md:text-base text-dom-graphite/85">{access}</p>
      </div>
      <div class="md:pl-2">
        <a
          href="#product-form"
          class="w-full md:w-auto px-8 py-3 bg-dom-gold text-white rounded-xl font-montserrat font-semibold text-base hover:bg-dom-goldDark transition shadow-[0_10px_24px_rgba(166,120,50,0.32)] inline-flex justify-center"
        >
          Подать заявку
        </a>
      </div>
    </div>
  </div>
</section>
