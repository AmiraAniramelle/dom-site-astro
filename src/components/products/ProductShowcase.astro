---
interface Props {
  title: string;
  modulesCount: number;
  format: string;
  access: string;
}

const { title, modulesCount, format, access } = Astro.props as Props;
---

<section class="flex w-full flex-col gap-6">
  <div class="product-video-block overflow-hidden rounded-2xl">
    <div
      class="product-video-inner text-center px-5 py-10 md:px-8 md:py-16"
    >
      <span
        class="mb-4 inline-block rounded-full border border-dom-gold/30 bg-white/10 px-6 py-2 font-montserrat text-sm text-dom-beige/85"
      >
        Видео-презентация программы
      </span>
      <h3 class="mb-2 font-messiri text-3xl text-dom-gold md:text-4xl">{title}</h3>
      <p class="font-montserrat text-sm text-dom-beige/75">
        Ключевые смыслы, формат и результат прохождения
      </p>
    </div>
  </div>

  <div class="product-light-card rounded-2xl p-6">
    <div
      class="grid grid-cols-1 gap-0 md:grid-cols-[1fr_auto_1fr_auto_1fr_auto] md:items-center md:gap-4"
    >
      <div
        class="border-b border-dom-gold/15 py-3 text-center md:border-b-0 md:text-left"
      >
        <p class="font-montserrat text-[10px] uppercase tracking-[0.12em] text-dom-graphite/60">
          Формат
        </p>
        <p class="font-montserrat text-xl font-semibold text-dom-graphite md:text-2xl">{format}</p>
      </div>
      <div class="hidden h-12 w-px bg-dom-gold/35 md:block" aria-hidden="true"></div>
      <div
        class="border-b border-dom-gold/15 py-3 text-center md:border-b-0 md:text-left"
      >
        <p class="font-montserrat text-[10px] uppercase tracking-[0.12em] text-dom-graphite/60">
          Материалы
        </p>
        <p class="font-montserrat text-xl font-semibold text-dom-graphite md:text-2xl">
          {modulesCount} модулей
        </p>
      </div>
      <div class="hidden h-12 w-px bg-dom-gold/35 md:block" aria-hidden="true"></div>
      <div
        class="border-b border-dom-gold/15 py-3 text-center md:border-b-0 md:text-left"
      >
        <p class="font-montserrat text-[10px] uppercase tracking-[0.12em] text-dom-graphite/60">
          Доступ
        </p>
        <p class="font-montserrat text-xl font-semibold text-dom-graphite md:text-2xl">{access}</p>
      </div>
      <a
        href="#product-enroll-block"
        class="mt-4 inline-flex w-full items-center justify-center rounded-xl bg-dom-gold px-8 py-3 font-montserrat text-base font-semibold text-white shadow-[0_10px_24px_rgba(166,120,50,0.32)] transition hover:bg-dom-gold-dark md:mt-0 md:w-auto"
      >
        Подать заявку
      </a>
    </div>
  </div>
</section>

<style>
  .product-video-block {
    background: linear-gradient(180deg, #38332d, #2f2923);
  }
</style>
