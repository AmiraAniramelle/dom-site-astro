---
/**
 * Единый hero продукта (ТЗ TZ-ProductHero-Redesign.md): центрирование, опциональное YouTube, мета-полоска.
 */
import { domButtonTextLink } from '../../data/ui/domButtons';
import { dsBodyLight, dsEyebrow, dsH1, dsMetaLabel, dsMetaValue } from '../../data/ui/domTypography';

export interface Props {
  backLink: { text: string; url: string };
  tag: string;
  format?: string;
  title: string;
  shortDesc: string;
  youtubeId?: string;
  videoCover?: string;
  primaryCta: { text: string; url: string };
  secondaryCta?: { text: string; url: string };
  meta?: Array<{ label: string; value: string }>;
}

const {
  backLink,
  tag,
  format,
  title,
  shortDesc,
  youtubeId,
  videoCover,
  primaryCta,
  secondaryCta,
  meta,
} = Astro.props;

const ytId = youtubeId?.trim() ?? '';
const showVideo = Boolean(ytId);
const ytPosterFallback = ytId ? `https://img.youtube.com/vi/${ytId}/hqdefault.jpg` : '';
const posterPreferred = videoCover?.trim();
const heroPosterSrc = posterPreferred || ytPosterFallback;
const embedSrc = ytId ? `https://www.youtube.com/embed/${ytId}?autoplay=1&rel=0` : '';

const formatLine =
  format?.trim() ||
  undefined;

const metaRows = Array.isArray(meta) ? meta : [];
const showMeta = metaRows.length > 0;
---

<section
  class="product-hero-new w-full rounded-2xl border border-dom-gold/20 p-5 text-center md:rounded-[2rem] md:p-8 lg:p-10"
  style="background: linear-gradient(145deg, rgba(255,252,244,0.98), rgba(246,233,203,0.92));"
>
  <div class="mb-4 text-left md:mb-6">
    <a href={backLink.url} class={domButtonTextLink}>
      {backLink.text}
    </a>
  </div>

  <div
    class="mb-5 flex flex-col flex-wrap items-center justify-center gap-2 max-md:w-full md:mb-6 md:flex-row md:gap-3"
  >
    <span
      class="inline-block max-md:w-full max-md:text-center rounded-full bg-dom-gold-dark px-5 py-2 font-montserrat text-[11px] font-bold uppercase tracking-[0.12em] text-white shadow-md md:text-xs"
    >
      {tag}
    </span>
    {
      formatLine ? (
        <span
          class:list={[
            'inline-block max-md:w-full max-md:text-center rounded-full border border-dom-gold/40 px-5 py-2 font-semibold',
            dsEyebrow,
          ]}
        >
          {formatLine}
        </span>
      ) : null
    }
  </div>

  <h1 class:list={['mb-3 md:mb-5', dsH1]}>
    {title}
  </h1>

  <p class:list={['mx-auto mb-5 max-w-3xl text-center md:mb-8', dsBodyLight]}>
    {shortDesc}
  </p>

  {
    showVideo && (
      <div
        class="relative mx-auto mb-6 w-full max-w-full md:mb-8"
        data-product-hero-video
        data-youtube-embed={embedSrc}
      >
        <div
          class="relative aspect-video overflow-hidden rounded-xl border border-dom-gold/20 shadow-[0_16px_40px_rgba(126,91,35,0.15)] md:rounded-2xl"
        >
          <button
            type="button"
            class="group absolute inset-0 z-[1] cursor-pointer border-0 bg-transparent p-0 text-left"
            data-ph-video-play
            aria-label="Воспроизвести видео о программе"
          >
            <img
              src={heroPosterSrc}
              alt={`${title} — обложка видео`}
              width="1280"
              height="720"
              class="absolute inset-0 h-full w-full object-cover transition-transform duration-500"
              loading="eager"
              decoding="async"
              onerror={`this.onerror=null;if(this.src!=='${ytPosterFallback}')this.src='${ytPosterFallback}'`}
            />
            <div
              class="pointer-events-none absolute inset-0 bg-gradient-to-t from-dom-graphite/35 via-transparent to-dom-graphite/5 transition-all duration-300 group-hover:from-dom-graphite/45"
              aria-hidden="true"
            />
            <span
              class="pointer-events-none absolute left-1/2 top-1/2 z-10 flex h-16 w-16 -translate-x-1/2 -translate-y-1/2 items-center justify-center rounded-full bg-white/90 shadow-[0_12px_28px_rgba(217,179,114,0.36)] backdrop-blur-sm transition-all duration-300 group-hover:scale-110 group-hover:bg-white group-hover:shadow-[0_16px_36px_rgba(217,179,114,0.45)] md:h-24 md:w-24"
              aria-hidden="true"
            >
              <svg
                class="ml-1 h-6 w-6 text-dom-gold-dark md:h-10 md:w-10"
                viewBox="0 0 24 24"
                fill="currentColor"
              >
                <path d="M8 5v14l11-7z" />
              </svg>
            </span>
          </button>
          <div class="absolute inset-0 z-[2] hidden bg-dom-graphite/5" data-ph-video-embed-wrap>
            <iframe
              class="h-full w-full"
              title={`Видео: ${title}`}
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; fullscreen"
              allowfullscreen
              loading="lazy"
              data-ph-video-iframe
            />
          </div>
        </div>
      </div>
    )
  }

  <div class="mb-6 flex flex-col items-center justify-center gap-3 sm:mb-8 sm:flex-row sm:gap-4">
    <a href={primaryCta.url} class="dom-btn-primary w-full md:w-auto text-center">
      {primaryCta.text}
    </a>
    {
      secondaryCta ? (
        <a href={secondaryCta.url} class="dom-btn-secondary w-full md:w-auto text-center">
          {secondaryCta.text}
        </a>
      ) : null
    }
  </div>

  {
    showMeta && (
      <div class="mx-auto w-full rounded-2xl border border-dom-gold/25 bg-white p-4 shadow-[0_10px_24px_rgba(126,91,35,0.1)] md:p-5">
        <div class="grid grid-cols-2 gap-3 md:grid-cols-4 md:items-center md:gap-4">
          {metaRows.map((row, i) => (
            <div
              class:list={[
                'text-center py-3 md:py-0',
                i < 2 ? 'border-b border-dom-gold/15 md:border-b-0' : '',
                i < 3 ? 'md:border-r md:border-dom-gold/20' : '',
              ]}
            >
              <p class={dsMetaLabel}>
                {row.label}
              </p>
              <p class={dsMetaValue}>
                {row.value}
              </p>
            </div>
          ))}
        </div>
      </div>
    )
  }
</section>

{
  showVideo && (
    <script is:inline>
      (function () {
        function initProductHeroVideos() {
          document.querySelectorAll('[data-product-hero-video]').forEach(function (root) {
            var url = root.getAttribute('data-youtube-embed');
            var btn = root.querySelector('[data-ph-video-play]');
            var embedWrap = root.querySelector('[data-ph-video-embed-wrap]');
            var iframe = root.querySelector('[data-ph-video-iframe]');
            if (!url || !btn || !embedWrap || !iframe) return;
            btn.addEventListener('click', function () {
              iframe.setAttribute('src', url);
              embedWrap.classList.remove('hidden');
              btn.classList.add('hidden');
            });
          });
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', initProductHeroVideos);
        } else {
          initProductHeroVideos();
        }
      })();
    </script>
  )
}
