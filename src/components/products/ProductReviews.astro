---
interface Props {
  reviews: Array<{ text: string; author: string }>;
}

const { reviews } = Astro.props as Props;

if (!Array.isArray(reviews) || reviews.length === 0) {
  return;
}
---

<section class="mx-auto w-full max-w-5xl">
  <h2 class="mb-12 text-center font-messiri text-4xl text-dom-graphite md:text-5xl">
    Изменения участников
  </h2>

  <div class="grid grid-cols-1 gap-6 md:grid-cols-2 md:gap-10">
    {reviews.map((rev) => (
      <article class="product-light-card relative rounded-2xl p-6 md:p-10">
        <span
          class="quote-mark absolute left-6 top-4 font-serif text-5xl text-dom-gold/20 md:text-7xl"
          aria-hidden="true"
        >
          &ldquo;
        </span>
        <p class="relative z-10 mb-8 font-montserrat text-base italic leading-relaxed text-dom-graphite/85">
          {rev.text}
        </p>
        <p class="font-montserrat text-base font-semibold text-dom-gold-dark">— {rev.author}</p>
      </article>
    ))}
  </div>
</section>
