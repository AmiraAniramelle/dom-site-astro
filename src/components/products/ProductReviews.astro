---
import { dsBody, dsH2 } from '../../data/ui/domTypography';

interface Props {
  reviews: Array<{ text: string; author: string }>;
}

const { reviews } = Astro.props as Props;

if (!Array.isArray(reviews) || reviews.length === 0) {
  return;
}
---

<section class="w-full">
  <h2 class:list={['mb-8 text-center text-dom-graphite md:mb-10', dsH2]}>Изменения участников</h2>

  <div class="grid grid-cols-1 gap-5 md:grid-cols-2 md:gap-6">
    {reviews.map((rev) => (
      <article class="product-light-card relative rounded-2xl p-5 md:p-8">
        <span
          class="quote-mark absolute left-6 top-4 font-messiri text-5xl text-dom-gold/20 md:text-6xl"
          aria-hidden="true"
        >
          &ldquo;
        </span>
        <p class:list={['relative z-10 mb-6 italic text-dom-graphite/85', dsBody]}>
          {rev.text}
        </p>
        <p class="font-montserrat text-sm font-semibold text-dom-gold-dark md:text-base lg:text-lg">
          — {rev.author}
        </p>
      </article>
    ))}
  </div>
</section>
