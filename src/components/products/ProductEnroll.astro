---
interface Props {
  title: string;
  shortDesc: string;
  price: string;
  tag: string;
  productSlug: string;
}

const { title, shortDesc, price, tag: _tag, productSlug } = Astro.props as Props;
---

<section
  id="product-enroll-block"
  class="product-enroll product-light-card rounded-[2.2rem] p-5 md:p-8 lg:p-12"
>
  <div class="grid grid-cols-1 gap-10 lg:grid-cols-2 lg:gap-10">
    <div class="product-light-card-inner rounded-3xl p-5 md:p-8">
      <p class="mb-4 font-montserrat text-xs uppercase tracking-[0.16em] text-dom-graphite/70">
        Условия участия
      </p>
      <h3 class="mb-4 font-messiri text-3xl text-dom-graphite md:text-4xl">{title}</h3>
      <p class="mb-6 font-montserrat text-base leading-relaxed text-dom-graphite/80">{shortDesc}</p>
      <p class="mb-2 font-messiri text-4xl text-dom-graphite md:text-5xl">{price}</p>
      <p class="mb-6 font-montserrat text-sm text-dom-graphite/75">
        После заявки свяжемся и уточним детали доступа.
      </p>
      <div class="prose prose-dom max-w-none">
        <slot />
      </div>
    </div>

    <div class="product-light-card-inner rounded-3xl p-5 md:p-8">
      <h4 class="mb-5 font-messiri text-2xl text-dom-graphite">Форма заявки</h4>
      <form class="flex flex-col space-y-4" data-enroll-form>
        <input type="hidden" name="productSlug" value={productSlug} />

        <input
          type="text"
          name="name"
          required
          placeholder="Ваше имя"
          aria-label="Ваше имя"
          class="product-light-input w-full rounded-xl border px-6 py-4 font-montserrat text-base text-dom-graphite outline-none placeholder:text-dom-graphite/30 focus:border-dom-gold/60 focus:ring-2 focus:ring-dom-gold/20 md:text-lg"
        />

        <input
          type="email"
          name="email"
          required
          placeholder="Электронная почта"
          aria-label="Электронная почта"
          class="product-light-input w-full rounded-xl border px-6 py-4 font-montserrat text-base text-dom-graphite outline-none placeholder:text-dom-graphite/30 focus:border-dom-gold/60 focus:ring-2 focus:ring-dom-gold/20 md:text-lg"
        />

        <input
          type="text"
          name="contact"
          required
          placeholder="Телефон / Telegram"
          aria-label="Телефон или Telegram"
          class="product-light-input w-full rounded-xl border px-6 py-4 font-montserrat text-base text-dom-graphite outline-none placeholder:text-dom-graphite/30 focus:border-dom-gold/60 focus:ring-2 focus:ring-dom-gold/20 md:text-lg"
        />

        <label class="mt-5 flex cursor-pointer items-start gap-3">
          <input type="checkbox" required class="mt-1" />
          <span class="font-montserrat text-sm leading-relaxed text-dom-graphite/85">
            Нажимая на кнопку, вы соглашаетесь на обработку персональных данных.
          </span>
        </label>

        <button
          type="submit"
          class="enroll-submit mt-6 w-full rounded-2xl bg-gold-gradient py-4 font-messiri text-xl tracking-wide text-white shadow-[0_12px_26px_rgba(166,120,50,0.34)] transition-all hover:brightness-105 md:text-2xl"
        >
          Занять место
        </button>

        <p class="mt-3 text-center font-montserrat text-sm text-dom-graphite/75">
          Ответим в рабочее время в течение 1–2 дней.
        </p>
      </form>
    </div>
  </div>
</section>
