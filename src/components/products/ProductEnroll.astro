---
import { dsBody, dsH2, dsH3, dsH4, dsPriceDisplay } from '../../data/ui/domTypography';

interface Props {
  title: string;
  shortDesc: string;
  price: string;
  tag: string;
  productSlug: string;
}

const { title, shortDesc, price, tag: _tag, productSlug } = Astro.props as Props;
---

<section
  id="product-enroll-block"
  class="product-enroll product-light-card rounded-[2.2rem] p-5 md:p-6 lg:p-8"
  aria-labelledby="product-enroll-heading"
>
  <h2 id="product-enroll-heading" class:list={['mb-6 text-center text-dom-graphite md:mb-8', dsH2]}>
    Запись на программу
  </h2>
  <div class="grid grid-cols-1 gap-8 lg:grid-cols-2 lg:gap-8">
    <div class="product-light-card-inner rounded-3xl p-5 md:p-6">
      <p class="mb-4 font-montserrat text-[11px] uppercase tracking-[0.12em] text-dom-graphite/70 md:text-xs">
        Условия участия
      </p>
      <h3 class:list={['mb-4 text-dom-graphite', dsH3]}>{title}</h3>
      <p class:list={['mb-6 text-dom-graphite/80', dsBody]}>{shortDesc}</p>
      <p class:list={['mb-2', dsPriceDisplay]}>{price}</p>
      <p class:list={['mb-6 text-dom-graphite/75', dsBody]}>
        После заявки свяжемся и уточним детали доступа.
      </p>
      <div class="prose prose-dom max-w-none">
        <slot />
      </div>
    </div>

    <div class="product-light-card-inner rounded-3xl p-5 md:p-6">
      <h4 class:list={['mb-4 text-dom-graphite', dsH4]}>Форма заявки</h4>
      <form class="flex flex-col space-y-4" data-enroll-form>
        <input type="hidden" name="productSlug" value={productSlug} />

        <input
          type="text"
          name="name"
          required
          placeholder="Ваше имя"
          aria-label="Ваше имя"
          class="product-light-input w-full rounded-xl border px-6 py-4 font-montserrat text-sm text-dom-graphite outline-none placeholder:text-dom-graphite/30 focus:border-dom-gold/60 focus:ring-2 focus:ring-dom-gold/20 md:text-base lg:text-lg"
        />

        <input
          type="email"
          name="email"
          required
          placeholder="Электронная почта"
          aria-label="Электронная почта"
          class="product-light-input w-full rounded-xl border px-6 py-4 font-montserrat text-sm text-dom-graphite outline-none placeholder:text-dom-graphite/30 focus:border-dom-gold/60 focus:ring-2 focus:ring-dom-gold/20 md:text-base lg:text-lg"
        />

        <input
          type="text"
          name="contact"
          required
          placeholder="Телефон / Telegram"
          aria-label="Телефон или Telegram"
          class="product-light-input w-full rounded-xl border px-6 py-4 font-montserrat text-sm text-dom-graphite outline-none placeholder:text-dom-graphite/30 focus:border-dom-gold/60 focus:ring-2 focus:ring-dom-gold/20 md:text-base lg:text-lg"
        />

        <label class="mt-5 flex cursor-pointer items-start gap-3">
          <input type="checkbox" required class="mt-1" />
          <span class:list={[dsBody, 'text-dom-graphite/85']}>
            Нажимая на кнопку, вы соглашаетесь на обработку персональных данных.
          </span>
        </label>

        <button type="submit" class="dom-btn-primary mt-6 w-full">
          Занять место
        </button>

        <p class:list={['mt-3 text-center text-dom-graphite/75', dsBody]}>
          Ответим в рабочее время в течение 1–2 дней.
        </p>
      </form>
    </div>
  </div>
</section>
