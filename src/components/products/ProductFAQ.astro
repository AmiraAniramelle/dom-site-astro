---
import { dsBody, dsH2, dsH4 } from '../../data/ui/domTypography';

interface Props {
  items: Array<{ q: string; a: string }>;
}

const { items } = Astro.props as Props;
const hasItems = Array.isArray(items) && items.length > 0;
---

{
  hasItems ? (
    <section class="w-full">
      <h2 class:list={['mb-8 text-center text-dom-graphite md:mb-10', dsH2]}>Частые вопросы</h2>

      <div class="space-y-4">
        {items.map((item) => (
          <details class="product-light-panel group cursor-pointer rounded-xl p-5 transition-colors hover:border-dom-gold/40 md:p-6">
            <summary
              class:list={[
                'flex list-none items-center justify-between font-semibold outline-none transition-colors group-open:text-dom-gold-dark [&::-webkit-details-marker]:hidden',
                dsH4,
              ]}
            >
              <span>{item.q}</span>
              <span class="font-montserrat text-2xl font-light text-dom-gold transition-transform group-open:rotate-45 md:text-3xl">
                +
              </span>
            </summary>
            <div class:list={['mt-5 border-t border-dom-gold/15 pt-5 text-dom-graphite/80', dsBody]}>
              {item.a}
            </div>
          </details>
        ))}
      </div>
    </section>
  ) : null
}
