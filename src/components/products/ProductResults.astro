---
interface Props {
  results: string[];
  modules: Array<{ name: string; desc: string }>;
}

const { results, modules } = Astro.props as Props;
const hasResults = Array.isArray(results) && results.length > 0;
const hasModules = Array.isArray(modules) && modules.length > 0;
---

{
  hasResults || hasModules ? (
    <section class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="product-results-card rounded-[2.5rem] p-10 md:p-16 mb-24 grid grid-cols-1 lg:grid-cols-2 gap-16 relative overflow-hidden border border-dom-gold/25 bg-[linear-gradient(145deg,rgba(255,252,244,0.98),rgba(246,233,203,0.9))] shadow-[0_14px_34px_rgba(90,63,25,0.16)]">
        <div>
          <h2 class="font-messiri text-4xl md:text-5xl text-dom-graphite mb-6">Что вы получите:</h2>
          {hasResults ? (
            <ul class="space-y-4">
              {results.map((item) => (
                <li class="font-montserrat text-sm md:text-base text-dom-graphite/85 border-l-2 border-dom-gold/50 pl-4">
                  {item}
                </li>
              ))}
            </ul>
          ) : null}
        </div>

        <div>
          <h2 class="font-messiri text-4xl md:text-5xl text-dom-graphite mb-6">Как это работает:</h2>
          {hasModules ? (
            <ul class="space-y-4">
              {modules.map((mod) => (
                <li class="rounded-xl border border-dom-gold/20 bg-white/65 px-4 py-3">
                  <h3 class="font-messiri text-2xl text-dom-graphite mb-2">{mod.name}</h3>
                  <p class="font-montserrat text-sm md:text-base text-dom-graphite/85">{mod.desc}</p>
                </li>
              ))}
            </ul>
          ) : null}
        </div>
      </div>
    </section>
  ) : null
}
