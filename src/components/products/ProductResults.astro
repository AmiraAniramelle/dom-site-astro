---
import { dsBody, dsH2, dsH3, dsH4 } from '../../data/ui/domTypography';

interface Props {
  results: string[];
  modules: Array<{ name: string; desc: string }>;
}

const { results, modules } = Astro.props as Props;
const hasResults = Array.isArray(results) && results.length > 0;
const hasModules = Array.isArray(modules) && modules.length > 0;
---

{
  hasResults || hasModules ? (
    <section class="w-full" aria-labelledby="product-results-heading">
      <h2 id="product-results-heading" class:list={['mb-6 text-center text-dom-graphite md:mb-8', dsH2]}>
        Результаты и структура программы
      </h2>
      <div
        class="results-wrap product-light-card flex flex-col gap-8 rounded-[2.5rem] p-5 lg:grid lg:grid-cols-2 lg:gap-10 lg:p-10"
      >
        <div class="mb-8 lg:mb-0">
          <h3 class:list={['mb-5 text-dom-graphite md:mb-7', dsH3]}>Что вы получите:</h3>
          {hasResults ? (
            <ul class="space-y-4">
              {results.map((item) => (
                <li class="product-light-panel flex items-start rounded-xl p-4 transition-colors hover:border-dom-gold/40 md:p-5">
                  <span class="mr-4 mt-1 text-2xl font-bold text-dom-gold" aria-hidden="true">
                    ✓
                  </span>
                  <span class:list={['whitespace-pre-line text-dom-graphite/80', dsBody]}>
                    {item}
                  </span>
                </li>
              ))}
            </ul>
          ) : null}
        </div>

        <div>
          <h3 class:list={['mb-5 text-dom-graphite md:mb-7', dsH3]}>Как это работает:</h3>
          {hasModules ? (
            <ul class="space-y-0">
              {modules.map((mod) => (
                <li class="group relative border-l-2 border-dom-gold/30 pb-6 pl-6 md:pl-8">
                  <span
                    class="absolute -left-[9px] top-1 h-4 w-4 rounded-full border-2 border-dom-gold bg-dom-beige transition-colors group-hover:bg-dom-gold"
                    aria-hidden="true"
                  />
                  <h4 class:list={['mb-2', dsH4]}>{mod.name}</h4>
                  <p class:list={['text-dom-graphite/70', dsBody]}>{mod.desc}</p>
                </li>
              ))}
            </ul>
          ) : null}
        </div>
      </div>
    </section>
  ) : null
}
