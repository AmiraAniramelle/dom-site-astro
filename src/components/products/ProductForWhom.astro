---
interface Props {
  items: Array<{ title: string; desc: string }>;
}

const { items } = Astro.props as Props;
---

{
  items && items.length > 0 ? (
    <section class="mx-auto w-full max-w-5xl">
      <div class="mb-10 text-center">
        <h2 class="font-messiri text-4xl text-dom-graphite md:text-5xl">Для кого этот путь?</h2>
      </div>
      <div class="grid grid-cols-1 gap-4 md:grid-cols-3 md:gap-8">
        {items.map((item) => (
          <article class="for-whom-card product-light-card rounded-2xl p-6 transition-all duration-300 hover:border-dom-gold/50 hover:shadow-xl md:p-8">
            <h4 class="mb-3 font-messiri text-2xl text-dom-graphite">{item.title}</h4>
            <p class="font-montserrat text-sm leading-relaxed text-dom-graphite/70">{item.desc}</p>
          </article>
        ))}
      </div>
    </section>
  ) : null
}
