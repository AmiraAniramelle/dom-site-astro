---
import { dsBody, dsH2, dsH4 } from '../../data/ui/domTypography';

interface Props {
  items: Array<{ title: string; desc: string }>;
}

const { items } = Astro.props as Props;
---

{
  items && items.length > 0 ? (
    <section class="w-full">
      <div class="mb-8 text-center">
        <h2 class:list={['text-dom-graphite', dsH2]}>Для кого этот путь?</h2>
      </div>
      <div class="grid grid-cols-1 gap-5 md:grid-cols-3 md:gap-6">
        {items.map((item) => (
          <article class="for-whom-card product-light-card rounded-2xl p-5 transition-all duration-300 hover:border-dom-gold/50 hover:shadow-xl md:p-6">
            <h3 class:list={['mb-3 text-dom-graphite', dsH4]}>{item.title}</h3>
            <p class:list={['text-dom-graphite/70', dsBody]}>{item.desc}</p>
          </article>
        ))}
      </div>
    </section>
  ) : null
}
